    <!-- 二、簽核決議 -->
    <form id="frmSign" class="card mb-3">
        <div class="card-header fw-bold">二、簽核決議</div>
        <div class="card-body">
            <div class="row g-3">

                <div id="assignContainer"></div>


                <!-- 決議 -->
                <div class="row g-3 align-items-center">
                    <label class="col-12 col-md-2 col-form-label text-start text-md-end">決議</label>
                    <div class="col-12 col-md-10">
                        <div class="decision-group">
                            <label class="decision-card decision-approve" for="dec-approve">
                                <input type="radio" class="btn-check" name="agreement" id="dec-approve" value="agree" autocomplete="off" checked="">
                                <div class="decision-content">
                                    <div class="decision-title">同意</div>
                                    <div class="decision-desc">簽核通過，流程繼續</div>
                                </div>
                            </label>

                            <label class="decision-card decision-reject" for="dec-disagree">
                                <input type="radio" class="btn-check" name="agreement" id="dec-disagree" value="disagree" autocomplete="off">
                                <div class="decision-content">
                                    <div class="decision-title">退回</div>
                                    <div class="decision-desc">退回前序關卡補正</div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- 退回到第N關(僅在「退回」時顯示) -->
                <div class="row g-3 align-items-center" id="retTargetRow" style="display: none;">
                    <label for="ret-seq" class="col-12 col-md-2 col-form-label text-start text-md-end">退回到</label>
                    <div class="col-12 col-md-10">
                        <select id="ret-seq" name="return_to_sequence" class="form-select"><option value="">(無可退回關卡)</option></select>
                        <div class="form-text">僅可退回至已簽畢的前序關卡</div>
                    </div>
                </div>

                <!-- 簽核意見 -->
                <div class="row g-3">
                    <label for="comment" class="col-12 col-md-2 col-form-label text-start text-md-end">簽核意見</label>
                    <div class="col-12 col-md-10">
                        <textarea id="comment" name="comment" class="form-control" rows="4" placeholder="請輸入簽核意見(退回時必填)"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer d-flex justify-content-end gap-2">
            <a id="btnBack" href="/ApprovalProcess/Index" class="btn btn-outline-secondary">返回</a>
            <button id="btnSubmit" type="submit" class="btn btn-primary">送出簽核</button>
        </div>
    </form>

</div>