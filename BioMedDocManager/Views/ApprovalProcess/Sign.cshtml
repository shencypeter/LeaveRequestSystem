@using System.Linq
@using System.Collections.Generic
@using Newtonsoft.Json.Linq
@using Microsoft.AspNetCore.Html
@model JObject

@{
    Layout = "_AssetLayout";

    var approvalInstance = Model["approval_instance"] as JObject ?? new JObject();
    var approvalProcess = Model["approval_process"] as JArray ?? new JArray();
    var rejectHistory = Model["reject_history"] as JObject ?? new JObject();

    var rejectGroups = rejectHistory.Properties()
        .OrderBy(p => ParseRejectKeyOrder(p.Name))
        .ToList();

    var processRows = approvalProcess
        .OfType<JToken>()
        .Select(x => x as JObject)
        .Where(x => x != null)
        .OrderBy(x => ParseInt(x["approval_process_sequence"]))
        .ToList();

    var currentProcess = processRows.FirstOrDefault(x => !IsSigned(x));

    var currentSeq = currentProcess != null
        ? ParseInt(currentProcess["approval_process_sequence"])
        : 0;

    var nextProcess = currentProcess == null
        ? null
        : processRows.FirstOrDefault(x =>
            ParseInt(x["approval_process_sequence"]) > currentSeq &&
            !IsSigned(x));

    var isFlowCompleted = currentProcess == null;

    // 先依你目前的假設: 當前畫面就是輪到這個人簽
    // 之後若要接登入者 / O365 / employeeId 比對，再改這裡即可
    var isMyTurn = !isFlowCompleted;

    var currentSigner = currentProcess == null
        ? ""
        : GetDisplayName(currentProcess);

    var nextSigner = nextProcess == null
        ? ""
        : GetDisplayName(nextProcess);

    var rejectableSteps = processRows
        .Where(x =>
            IsSigned(x) &&
            ParseInt(x["approval_process_sequence"]) < currentSeq)
        .GroupBy(x => ParseInt(x["approval_process_sequence"]))
        .Select(g => g.First())
        .OrderBy(x => ParseInt(x["approval_process_sequence"]))
        .ToList();

    var starterProcess = processRows.FirstOrDefault();
    var starterSigner = starterProcess == null
        ? "承辦人"
        : GetDisplayName(starterProcess);
}

<div class="p-3">
    <h2 class="mb-3">簽核作業</h2>

    <!-- 一、簽核歷程 -->
    <div class="card mb-3">
        <div class="card-header fw-bold">一、簽核歷程</div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="approverDetailTable" class="table table-sm table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="text-center">序號</th>
                            <th class="text-center">階段</th>
                            <th class="text-center">應簽核人</th>
                            <th class="text-center">實際簽核人</th>
                            <th class="text-center">簽核時間</th>
                            <th class="text-center">結果</th>
                            <th>意見</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (processRows.Count > 0)
                        {
                            foreach (var process in processRows)
                            {
                                var comment = SafeText(process["approval_process_comment"]);

                                <tr>
                                    <td class="text-center">@SafeText(process["approval_process_sequence"], "-")</td>
                                    <td>
                                        @SafeText(process["approval_process_step_name"], "-")
                                        @if (IsParallelStep(process))
                                        {
                                            <span class="ms-1 text-primary small">(並簽)</span>
                                        }
                                    </td>
                                    <td>
                                        @Html.Raw(PersonBlock(
                                        process["approval_process_employee_cname"],
                                                                process["approval_process_employee_id"],
                                                                process["approval_process_employee_department"],
                                                                process["approval_process_employee_job_title"]))
                            </td>
                            <td>
                                @Html.Raw(GetActualSignerHtml(process))
                            </td>
                            <td class="text-nowrap text-center">
                                @FormatDateTime(process["approval_process_sign_time"])
                            </td>
                            <td class="text-center">
                                @RenderResultBadge(process)
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(comment) ? "-" : comment)</td>
                        </tr>
                                                }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">查無簽核資料</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 二、簽核決議 -->
    <form id="frmSign" class="card mb-3" method="post">
        <div class="card-header fw-bold">二、簽核決議</div>

        <div class="card-body">
            <div class="row g-3">
                <div id="assignContainer"></div>

                <!-- 處理決策 -->
                <div class="row g-3 align-items-center" id="retTargetRow">
                    <label class="col-12 col-md-2 col-form-label text-start text-md-end">
                        處理決策
                    </label>

                    <div class="col-12 col-md-10">
                        @if (isMyTurn)
                        {
                            <select id="ret-seq" name="decision" class="form-select" required style="height:25px">
                                <option value="" selected disabled>👤 @currentSigner 您好，請選擇...</option>

                                <optgroup label="✅ 簽核通過">
                                    @if (nextProcess != null)
                                    {
                                        <option value="approve:@ParseInt(nextProcess["approval_process_sequence"])">
                                            ✅ 送往下一關 @nextProcess["approval_process_step_name"]（@nextSigner）
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="approve:complete">
                                            🚀 完成簽核（流程結束）
                                        </option>
                                    }
                                </optgroup>

                                @if (rejectableSteps.Any())
                                {
                                    <optgroup label="↩️ 退回前序關卡">
                                        @foreach (var step in rejectableSteps)
                                        {
                                            var seq = ParseInt(step["approval_process_sequence"]);
                                            var stepName = SafeText(step["approval_process_step_name"], "-");
                                            var signerName = GetDisplayName(step);

                                            <option value="reject:@seq">
                                                ↩️ 第 @seq 關 - @stepName - @signerName
                                            </option>
                                        }

                                        <option value="reject:terminate">
                                            🛑 直接終止流程（to @starterSigner）
                                        </option>
                                    </optgroup>
                                }
                            </select>

                            <div class="form-text">
                                選擇後送出，流程將依您的決策前進。
                            </div>
                        }
                        else
                        {
                            <div class="form-control d-flex justify-content-between align-items-center bg-light">
                                @if (isFlowCompleted)
                                {
                                    <span>✅ 此流程已完成</span>
                                }
                                else
                                {
                                    <span>🕒 目前由 <strong>@currentSigner</strong> 簽核中</span>
                                }

                                <span class="badge bg-secondary">
                                    @(isFlowCompleted ? "完成" : "等待中")
                                </span>
                            </div>

                            <div class="form-text">
                                @(isFlowCompleted ? "流程已結束。" : "🚧 尚未輪到您操作，請稍候。")
                            </div>
                        }
                    </div>
                </div>

                <!-- 簽核意見 -->
                <div class="row g-3">
                    <label for="comment" class="col-12 col-md-2 col-form-label text-start text-md-end">
                        簽核意見
                    </label>
                    <div class="col-12 col-md-10">
                        <textarea id="comment"
                                  name="comment"
                                  class="form-control"
                                  rows="4"
                                  placeholder="請輸入簽核意見（退回時必填）"
                                  @(isMyTurn ? null : "disabled")></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer d-flex justify-content-end gap-2">
            <a id="btnBack" href="/ApprovalProcess/Index" class="btn btn-outline-secondary">返回</a>

            @if (isMyTurn)
            {
                <button id="btnSubmit" type="submit" class="btn btn-primary">送出簽核</button>
            }
        </div>
    </form>
</div>

@functions {
    public string SafeText(JToken token, string fallback = "")
    {
        return token == null ? fallback : token.ToString();
    }

    public int ParseInt(JToken token, int fallback = 0)
    {
        if (token == null)
        {
            return fallback;
        }

        int n;
        return int.TryParse(token.ToString(), out n) ? n : fallback;
    }

    public string FormatDateTime(JToken token)
    {
        DateTime dt;
        if (token != null && DateTime.TryParse(token.ToString(), out dt))
        {
            return dt.ToString("yyyy-MM-dd HH:mm");
        }

        return "-";
    }

    public string PersonBlock(JToken nameToken, JToken idToken, JToken deptToken, JToken titleToken)
    {
        var name = SafeText(nameToken, "-");
        var id = SafeText(idToken);
        var dept = SafeText(deptToken);
        var title = SafeText(titleToken);

        var firstLine = string.IsNullOrWhiteSpace(id)
            ? name
            : string.Format("{0} ({1})", name, id);

        var secondLineParts = new List<string>();

        if (!string.IsNullOrWhiteSpace(dept))
        {
            secondLineParts.Add(dept);
        }

        if (!string.IsNullOrWhiteSpace(title))
        {
            secondLineParts.Add(title);
        }

        var secondLine = string.Join("／", secondLineParts);

        if (string.IsNullOrWhiteSpace(secondLine))
        {
            return firstLine;
        }

        return firstLine + "<div class=\"text-muted small\">" + secondLine + "</div>";
    }

    public string GetActualSignerHtml(JToken process)
    {
        var agentId = SafeText(process["approval_process_agent_employee_id"]);

        if (!string.IsNullOrWhiteSpace(agentId))
        {
            return PersonBlock(
                process["approval_process_agent_employee_cname"],
                process["approval_process_agent_employee_id"],
                process["approval_process_agent_employee_department"],
                process["approval_process_agent_employee_job_title"]
            );
        }

        if (IsSigned(process as JObject))
        {
            return PersonBlock(
                process["approval_process_employee_cname"],
                process["approval_process_employee_id"],
                process["approval_process_employee_department"],
                process["approval_process_employee_job_title"]
            );
        }

        return "-";
    }

    public string GetDisplayName(JObject process)
    {
        if (process == null)
        {
            return "-";
        }

        var name = SafeText(process["approval_process_employee_cname"], "-");
        return name;
    }

    public bool IsSigned(JObject process)
    {
        if (process == null)
        {
            return false;
        }

        var agreementToken = process["approval_process_agreement"];
        int agreement;
        if (agreementToken != null && int.TryParse(agreementToken.ToString(), out agreement))
        {
            return agreement == 1 || agreement == 0;
        }

        DateTime dt;
        return DateTime.TryParse(process["approval_process_sign_time"]?.ToString(), out dt);
    }

    public bool IsParallelStep(JObject process)
    {
        if (process == null)
        {
            return false;
        }

        var stepName = SafeText(process["approval_process_step_name"]).Trim();
        return stepName.Contains("並簽");
    }

    public IHtmlContent RenderResultBadge(JToken process)
    {
        var agreementToken = process["approval_process_agreement"];
        int agreement;

        if (agreementToken != null && int.TryParse(agreementToken.ToString(), out agreement))
        {
            if (agreement == 1)
            {
                return new HtmlString("<span class=\"badge bg-success\">同意</span>");
            }

            if (agreement == 0)
            {
                var returnToToken = process["approval_process_return_to_sequence"];
                int returnTo;

                if (returnToToken != null && int.TryParse(returnToToken.ToString(), out returnTo))
                {
                    return new HtmlString("<span class=\"badge bg-danger\">退回第 " + returnTo + " 關</span>");
                }

                return new HtmlString("<span class=\"badge bg-danger\">退回</span>");
            }
        }

        return new HtmlString("<span class=\"badge bg-secondary\">待簽核</span>");
    }


    string HumanTime(DateTime? dt)
    {
        if (dt == null)
            return "-";

        var span = DateTime.Now - dt.Value;

        if (span.TotalMinutes < 1)
            return "剛剛";
        if (span.TotalHours < 1)
            return $"{(int)span.TotalMinutes} 分鐘前";
        if (span.TotalHours < 24)
            return $"{(int)span.TotalHours} 小時前";
        if (span.TotalDays < 2)
            return "昨天";
        if (span.TotalDays < 7)
            return $"{(int)span.TotalDays} 天前";

        return dt.Value.ToString("yyyy/MM/dd HH:mm");
    }

    public int ParseRejectKeyOrder(string key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return int.MaxValue;
        }

        key = key.Trim().ToUpperInvariant();

        if (key.StartsWith("R"))
        {
            key = key.Substring(1);
        }

        int n;
        return int.TryParse(key, out n) ? n : int.MaxValue;
    }
}