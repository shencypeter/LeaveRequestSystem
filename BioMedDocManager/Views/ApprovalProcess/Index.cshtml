@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_AssetLayout";

    string HumanizeDate(string? iso)
    {
        if (string.IsNullOrWhiteSpace(iso))
            return "";

        if (!DateTime.TryParse(iso, out var dt))
            return iso;

        var now = DateTime.Now;
        var diff = now - dt;

        if (diff.TotalSeconds < 0)
            return dt.ToString("yyyy/MM/dd HH:mm");

        if (diff.TotalSeconds < 10)
            return "剛剛";

        if (diff.TotalMinutes < 1)
            return "< 1 分鐘前";

        if (diff.TotalHours < 1)
            return "< 1 小時前";

        if (dt.Date == now.Date)
            return "今天稍早";

        return dt.ToString("yyyy/MM/dd HH:mm");
    }
}

<div class="p-3">
    <h2 class="mb-3">我的簽核紀錄</h2>

    <!-- 查詢卡片(獨立，不掛在 bootstrapTable.toolbar) -->
    <form id="frmQuery" class="card shadow-sm mb-3">
        <div class="card-body py-3">
            <div class="row g-3 align-items-center">
                <!-- 申請日期(外層 4/8；內容再切左右各半) -->
                <div class="col-12 col-md-6">
                    <div class="row align-items-center">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end text-start fw-bold">申請日期</label>
                        <div class="col-12 col-sm-8">
                            <div class="row g-2">
                                <div class="col-12 col-lg-6">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">起</span>
                                        <input type="date" class="form-control form-control-sm" id="qDateFrom" name="date_from">
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">迄</span>
                                        <input type="date" class="form-control form-control-sm" id="qDateTo" name="date_to">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 表單類型(外層 4/8) -->
                <div class="col-12 col-md-3">
                    <div class="row align-items-center">
                        <label for="qFormType" class="col-12 col-sm-5 col-form-label text-sm-end text-start fw-bold">表單類型</label>
                        <div class="col-12 col-sm-7">
                            <select id="qFormType" name="form_type" class="form-select form-select-sm"><option value="">全部</option><option value="請假單">請假單</option></select>
                        </div>
                    </div>
                </div>

                <!-- 狀態(搬上來這裡；放成 select) -->
                <div class="col-12 col-md-3">
                    <div class="row align-items-center">
                        <label for="qStatus" class="col-12 col-sm-5 col-form-label text-sm-end text-start fw-bold">狀態</label>
                        <div class="col-12 col-sm-7">
                            <select id="qStatus" class="form-select form-select-sm">
                                <option value="待簽核" selected="">待簽核</option>
                                <option value="已簽核">已簽核</option>
                                <option value="">全部</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- 按鈕列(靠右) -->
                <div class="col-12">
                    <div class="text-end">
                        <button type="button" id="btnQuery" class="btn btn-primary btn-sm me-2">查詢</button>
                        <button type="button" id="btnReset" class="btn btn-outline-secondary btn-sm">重置</button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="bootstrap-table bootstrap5">
        <div class="fixed-table-toolbar">
            <div class="columns columns-right btn-group float-right">
                <button class="btn btn-secondary" type="button" name="refresh" aria-label="重新整理" title="重新整理"><i class="bi bi-arrow-clockwise"></i> </button><div class="keep-open btn-group">
                    <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-label="列" title="列">
                        <i class="bi bi-list-ul"></i>

                        <span class="caret"></span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end"><label class="dropdown-item dropdown-item-marker"><input type="checkbox" data-field="form_type" value="0" checked="checked"> <span>表單類型</span></label><label class="dropdown-item dropdown-item-marker"><input type="checkbox" data-field="form_id" value="1" checked="checked"> <span>原始表單單號</span></label><label class="dropdown-item dropdown-item-marker"><input type="checkbox" data-field="employee_name" value="2" checked="checked"> <span>申請人</span></label><label class="dropdown-item dropdown-item-marker"><input type="checkbox" data-field="approval_instance_submitted_at" value="3" checked="checked"> <span>申請人送出時間</span></label><label class="dropdown-item dropdown-item-marker"><input type="checkbox" data-field="approval_instance_status" value="4" checked="checked"> <span>狀態</span></label><label class="dropdown-item dropdown-item-marker"><input type="checkbox" data-field="approval_instance_sign_path" value="5" checked="checked"> <span>簽核路徑</span></label><label class="dropdown-item dropdown-item-marker"><input type="checkbox" data-field="_ops" value="6" checked="checked"> <span>操作</span></label></div>
                </div>
            </div>
            <div class="float-right search btn-group">
                <input class="form-control

        search-input" type="search" aria-label="搜尋" placeholder="搜尋" autocomplete="off">
            </div>
        </div>

        <div class="fixed-table-container" style="padding-bottom: 0px;">
            <div class="fixed-table-header" style="display: none;"><table></table></div>
            <div class="fixed-table-body">
                <div class="fixed-table-loading table table-bordered table-hover" style="top: 50px;">
                    <span class="loading-wrap">
                        <span class="loading-text" style="font-size: 32px;">正在努力地載入資料，請稍候</span>
                        <span class="animation-wrap"><span class="animation-dot"></span></span>
                    </span>

                </div>
                <table id="tblCR" class="table table-striped table-hover w-100 table-bordered">
                    <thead class=""><tr><th style="text-align: center; width: 120px; " data-field="form_type"><div class="th-inner sortable sortable-center both">表單類型</div><div class="fht-cell"></div></th><th style="text-align: center; width: 120px; " data-field="form_id"><div class="th-inner sortable sortable-center both">原始表單單號</div><div class="fht-cell"></div></th><th style="text-align: center; width: 120px; " data-field="employee_name"><div class="th-inner sortable sortable-center both">申請人</div><div class="fht-cell"></div></th><th style="text-align: center; width: 160px; " data-field="approval_instance_submitted_at"><div class="th-inner sortable sortable-center both desc">申請人送出時間</div><div class="fht-cell"></div></th><th style="text-align: center; width: 110px; " data-field="approval_instance_status"><div class="th-inner sortable sortable-center both">狀態</div><div class="fht-cell"></div></th><th style="text-align: center; " data-field="approval_instance_sign_path"><div class="th-inner ">簽核路徑</div><div class="fht-cell"></div></th><th style="text-align: center; width: 220px; " data-field="_ops"><div class="th-inner ">操作</div><div class="fht-cell"></div></th></tr></thead>
                    <tbody>
                        @{
                            var approvalProcessList = ViewData["ApprovalProcessList"] as List<Dictionary<string, object>> ?? new();
                        }
                        @foreach (var item in approvalProcessList)
                        {
                            var id = item.ContainsKey("approval_instance_id") && item["approval_instance_id"] != null
                            ? Convert.ToInt32(item["approval_instance_id"])
                            : 0;

                            var formType = item.ContainsKey("form_type") && item["form_type"] != null
                            ? item["form_type"]?.ToString()
                            : "";

                            var formId = item.ContainsKey("form_id") && item["form_id"] != null
                            ? item["form_id"]?.ToString()
                            : "";

                            var employeeName = item.ContainsKey("employee_name") && item["employee_name"] != null
                            ? item["employee_name"]?.ToString()
                            : "";

                            var submittedAtRaw = item.ContainsKey("approval_instance_submitted_at") && item["approval_instance_submitted_at"] != null
                            ? HumanizeDate(item["approval_instance_submitted_at"]?.ToString())
                            : "";

                            var status = item.ContainsKey("approval_instance_status") && item["approval_instance_status"] != null
                            ? item["approval_instance_status"]?.ToString()
                            : "";

                            var signPath = item.ContainsKey("approval_instance_sign_path") && item["approval_instance_sign_path"] != null
                            ? item["approval_instance_sign_path"]?.ToString()
                            : "";

                            <tr data-index="0" data-uniqueid="@id">
                                <td style="text-align: center; width: 120px; ">@formType</td>
                                <td style="text-align: center; width: 120px; ">@formId</td>
                                <td style="text-align: center; width: 120px; ">@employeeName</td>
                                <td style="text-align: center; width: 160px; ">@HumanizeDate(submittedAtRaw)</td>
                                <td style="text-align: center; width: 110px; ">
                                    @if (status == "簽核中" || status == "Pending" || status == "待簽核")
                                    {
                                        <span class="badge bg-warning">待簽核</span>
                                    }
                                    else if (status == "已完成" || status == "Completed" || status == "已簽核")
                                    {
                                        <span class="badge bg-secondary">已簽核</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark">@status</span>
                                    }
                                </td>
                                <td class="text-break" style="text-align: center; ">@signPath</td>
                                <td style="text-align: center; width: 220px;">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-primary dropdown-toggle"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false">
                                            功能
                                        </button>

                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item"
                                                   href="@Url.Action("Details", new { id = @id})" >
                                                    簽核詳細資料
                                                </a>
                                            </li>

                                            @if (status != "已完成" && status != "Completed")
                                            {
                                                <li>
                                                    <a class="dropdown-item"
                                                       href="@Url.Action("Edit", new { id = @id })">
                                                        強制編輯簽核人
                                                    </a>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="fixed-table-footer"></div>
        </div>
        <div class="fixed-table-pagination" style="display: block;">
            <div class="float-left pagination-detail">
                <span class="pagination-info">
                    顯示第 1 到第 1 項記錄，總共 1 項記錄
                </span><div class="page-list" style="display: none;">
                    每頁顯示 <div class="btn-group dropdown dropup">
                        <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <span class="page-size">
                                10
                            </span>
                            <span class="caret"></span>
                        </button>
                        <div class="dropdown-menu"><a class="dropdown-item active" href="#">10</a></div>
                    </div> 項記錄
                </div>
            </div><div class="float-right pagination" style="display: none;"><ul class="pagination"><li class="page-item page-pre"><a class="page-link" aria-label="上一頁" href="javascript:void(0)">‹</a></li><li class="page-item active"><a class="page-link" aria-label="第1頁" href="javascript:void(0)">1</a></li><li class="page-item page-next"><a class="page-link" aria-label="下一頁" href="javascript:void(0)">›</a></li></ul></div>
        </div>
    </div><div class="clearfix"></div>
</div>
