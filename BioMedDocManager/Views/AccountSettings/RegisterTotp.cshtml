@model BioMedDocManager.Models.TotpSetupViewModel
@{
    ViewData["Title"] = Loc.T("Totp.Setup.Title");
    Layout = "_NoNavLayout";

    var alert = TempData["_JSShowAlert"] as string;
    var success = TempData["_JSShowSuccess"] as string;
    bool isAlreadyEnabled = (ViewBag.IsAlreadyEnabled as bool?) == true;
}

<div class="m-4">
    <div class="pop">
        <h4 class="m-3 px-2">
            <i class="bi bi-shield-lock me-2"></i>@ViewData["Title"]
        </h4>

        @if (!string.IsNullOrEmpty(alert))
        {
            <div class="alert alert-danger mx-3 my-2">
                <i class="fas fa-exclamation-triangle me-2"></i>@alert
            </div>
        }

        @if (!string.IsNullOrEmpty(success))
        {
            <div class="alert alert-success mx-3 my-2">
                <i class="fas fa-check-circle me-2"></i>@success
            </div>
        }

        @if (isAlreadyEnabled)
        {
            <div class="alert alert-warning mx-3 my-2">
                <i class="fas fa-info-circle me-2"></i>
                @Loc.T("Totp.AlreadyEnabled.Warning")

                <div class="mt-3 text-end">
                    <button type="button"
                            class="btn btn-sm btn-danger"
                            data-bs-toggle="collapse"
                            data-bs-target="#totpSetupContent">
                        @Loc.T("Totp.ReRegister.Confirm")
                    </button>
                </div>
            </div>
        }

        <div id="totpSetupContent" class="collapse @(isAlreadyEnabled ? "" : "show")">

            <!-- ===== 說明 ===== -->
            <div class="mx-3 my-3">
                <ol>
                    <li>@Loc.T("Totp.Step.InstallApp")</li>
                    <li>
                        @Loc.T("Totp.Step.ChromeExtension")
                        <a href="https://chromewebstore.google.com/detail/authenticator/bhghoamapcdpbohphigoooaddinpkbai?hl=zh-TW"
                           target="_blank">Authenticator</a>
                    </li>
                    <li>@Loc.T("Totp.Step.ScanOrInput")</li>
                    <li>@Loc.T("Totp.Step.InputCode")</li>
                </ol>
            </div>

            <!-- ===== QR / 手動 ===== -->
            <div class="row my-3 mx-2">
                <div class="col-md-6 text-center mb-3">
                    <h5 class="mb-3">@Loc.T("Totp.Method.QrCode")</h5>
                    <div class="d-inline-block p-2 bg-white border rounded">
                        <img src="@Url.Action("TotpQrCode", "AccountSettings")"
                             class="totp-qr-img"
                             alt="TOTP QR Code" />
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <h5 class="mb-3">@Loc.T("Totp.Method.Manual")</h5>

                    <div class="mb-2">
                        <strong>@Html.DisplayNameFor(m => m.UserAccount)：</strong>
                        <span>@Model.UserAccount</span>
                    </div>

                    <div class="mb-2">
                        <strong>@Html.DisplayNameFor(m => m.Issuer)：</strong>
                        <span>@Model.Issuer</span>
                    </div>

                    <div class="mb-2">
                        <strong>@Html.DisplayNameFor(m => m.Secret)：</strong>
                        <code class="user-select-all">@Model.Secret</code>
                    </div>

                    <div class="text-muted small">
                        @Loc.T("Totp.Secret.Warning")
                    </div>
                </div>
            </div>

            <hr />

            <!-- ===== 輸入驗證碼 ===== -->
            <form asp-action="RegisterTotp" method="post" class="mx-3 my-3" target="_top">
                @Html.AntiForgeryToken()

                <div class="row align-items-center my-3">
                    <div class="col-md-2 col-form-label text-md-end text-start">
                        <span class="text-danger fw-bold">*</span>
                        <strong>@Html.LabelFor(m => m.Code)</strong>
                    </div>
                    <div class="col-md-10">
                        <input asp-for="Code"
                               class="form-control text-center text-uppercase"
                               maxlength="6"
                               inputmode="numeric"
                               autocomplete="one-time-code"
                               placeholder="@Loc.T("Totp.Code.Placeholder")" />

                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>
                </div>

                <div class="row align-items-center my-3">
                    <div class="col-md-12 d-flex justify-content-center">
                        <button type="submit"
                                class="btn2 btn-success mt-2 col-6 col-md-3 mx-1">
                            <i class="fas fa-check-circle"></i>
                            @Loc.T("Common.Enabled")
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">
        $(function () { });
    </script>
}
