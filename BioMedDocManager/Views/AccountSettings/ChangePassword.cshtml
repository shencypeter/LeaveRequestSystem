@model BioMedDocManager.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = Loc.T("AccountSettings.ChangePassword.Title");
    Layout = "_NoNavLayout";

    var policy = ViewBag.PasswordPolicy; // dynamic
}



<div class="m-4">
    <form class="PasswordForm" asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()
        <div class="pop">
            <div class="row align-items-center my-3">

                <!-- 使用者名稱 -->
                <div class="row align-items-center my-3">
                    <div class="col-md-2 col-form-label text-md-end text-start">
                        <strong>@Html.LabelFor(m => m.UserFullName)：</strong>
                    </div>
                    <div class="col-md-10">
                        <input asp-for="UserFullName" class="form-control" type="text" readonly="readonly" />
                    </div>
                </div>

                <!-- 使用者帳號 -->
                <div class="row align-items-center my-3">
                    <div class="col-md-2 col-form-label text-md-end text-start">
                        <strong>@Html.LabelFor(m => m.UserAccount)：</strong>
                    </div>
                    <div class="col-md-10">
                        <input asp-for="UserAccount" class="form-control" type="text" readonly="readonly" />
                    </div>
                </div>

                <!-- 密碼政策 -->
                <div id="passwordPolicyConfig"
                     data-enabled="@(policy?.Enabled == true ? "true" : "false")"
                     data-min-length="@(policy?.MinLength ?? 0)"
                     data-require-upper="@(policy?.RequireUpper == true ? "true" : "false")"
                     data-require-lower="@(policy?.RequireLower == true ? "true" : "false")"
                     data-require-digit="@(policy?.RequireDigit == true ? "true" : "false")"
                     data-require-special="@(policy?.RequireSpecial == true ? "true" : "false")"
                     data-special-chars="@((string)(policy?.SpecialCharSets ?? ""))"
                     class="d-none">
                </div>

                <!-- 原密碼 -->
                <div class="row align-items-center my-3">
                    <div class="col-md-2 col-form-label text-md-end text-start">
                        <span class="text-danger fw-bold">*</span><strong>@Html.LabelFor(m => m.UserCurrentPassword)：</strong>
                    </div>
                    <div class="col-md-10">
                        <div class="input-group">
                            <input asp-for="UserCurrentPassword" class="form-control" type="password" required="required" />
                            <button class="btn btn-outline-secondary togglePasswordButton" data-id="UserCurrentPassword" type="button">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="UserCurrentPassword" class="text-danger"></span>
                    </div>
                </div>

                <!-- 新密碼 -->
                <div class="row my-3">
                    <div class="col-md-2 col-form-label text-md-end text-start">
                        <span class="text-danger fw-bold">*</span><strong>@Html.LabelFor(m => m.UserNewPasswordHash)</strong>
                    </div>
                    <div class="col-md-10">

                        <div class="input-group">
                            <input asp-for="UserNewPasswordHash"
                                   class="form-control"
                                   type="password"
                                   required="required"
                                   data-target="UserConfirmPasswordHash"
                                   data-validation="UserNewPasswordHashValidation" />

                            <!-- 眼睛按鈕維持 data-id -->
                            <button class="btn btn-outline-secondary togglePasswordButton" data-id="UserNewPasswordHash" type="button">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>

                        <!-- 這個是「雙向驗證訊息」的顯示位置（由 data-validation 指定） -->
                        <span id="UserNewPasswordHashValidation" class="text-danger"></span>

                        @if (policy != null && policy.Enabled == true)
                        {
                            <div class="mb-1">
                                <div class="text-12 fw-bold">
                                    @Loc.T("PasswordPolicy.Title")
                                </div>

                                <ul id="passwordRulesList" class="text-12 mb-0 ps-3">

                                    <!-- 最小長度 -->
                                    <li class="password-rule text-muted" data-rule="minLength">
                                        @Loc.T("PasswordPolicy.MinLength.Prefix")
                                        @policy.MinLength
                                        @Loc.T("PasswordPolicy.MinLength.Suffix")
                                    </li>

                                    <!-- 大寫字母 -->
                                    @if (policy.RequireUpper == true)
                                    {
                                        <li class="password-rule text-muted" data-rule="upper">
                                            @Loc.T("PasswordPolicy.RequireUpper.Text")
                                        </li>
                                    }

                                    <!-- 小寫字母 -->
                                    @if (policy.RequireLower == true)
                                    {
                                        <li class="password-rule text-muted" data-rule="lower">
                                            @Loc.T("PasswordPolicy.RequireLower.Text")
                                        </li>
                                    }

                                    <!-- 數字 -->
                                    @if (policy.RequireDigit == true)
                                    {
                                        <li class="password-rule text-muted" data-rule="digit">
                                            @Loc.T("PasswordPolicy.RequireDigit.Text")
                                        </li>
                                    }

                                    <!-- 特殊符號 -->
                                    @if (policy.RequireSpecial == true)
                                    {
                                        <li class="password-rule text-muted" data-rule="special">
                                            @Loc.T("PasswordPolicy.RequireSpecial.Prefix")
                                            @policy.SpecialCharSets
                                            @Loc.T("PasswordPolicy.RequireSpecial.Suffix")
                                        </li>
                                    }

                                </ul>
                            </div>
                        }

                        <span asp-validation-for="UserNewPasswordHash" class="text-danger"></span>
                    </div>
                </div>

                <!-- 確認密碼 -->
                <div class="row align-items-center my-3">
                    <div class="col-md-2 col-form-label text-md-end text-start">
                        <span class="text-danger fw-bold">*</span><strong>@Html.LabelFor(m => m.UserConfirmPasswordHash)</strong>
                    </div>
                    <div class="col-md-10">

                        <div class="input-group">
                            <input asp-for="UserConfirmPasswordHash"
                                   class="form-control"
                                   type="password"
                                   required="required"
                                   data-target="UserNewPasswordHash"
                                   data-validation="UserConfirmPasswordHashValidation" />

                            <!-- 眼睛按鈕維持 data-id -->
                            <button class="btn btn-outline-secondary togglePasswordButton" data-id="UserConfirmPasswordHash" type="button">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>

                        <!-- 這個是「雙向驗證訊息」的顯示位置（由 data-validation 指定） -->
                        <span id="UserConfirmPasswordHashValidation" class="text-danger"></span>

                        <span asp-validation-for="UserConfirmPasswordHash" class="text-danger"></span>
                    </div>
                </div>


            </div>

            <div class="row align-items-center my-3">
                <div class="col-md-12 d-flex justify-content-center">
                    <button type="submit" class="btn2 btn-success mt-2 col-6 col-md-3 mx-1">
                        <i class="fas fa-check-circle"></i> @Loc.T("Common.Save")
                    </button>
                </div>
            </div>
            @if (ViewBag.Message != null)
            {
                <div class="row align-items-center my-3">
                    <div class="col-md-12 d-flex justify-content-center">
                        <div class="alert alert-success">訊息：@ViewBag.Message</div>
                    </div>
                </div>
            }
        </div>
    </form>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">
        $(function () {
            // 確認密碼
            CheckConfirmPassword();

            // 密碼顯示/隱藏（眼睛按鈕）
            passwordVisibilityListener();
            
            // 動態顯示已完成的密碼規則
            bindPasswordPolicyWatcher({
                configSelector: '#passwordPolicyConfig',
                rulesListSelector: '#passwordRulesList',
                inputSelector: '#UserNewPasswordHash',
                formSelector: '.PasswordForm',
                errorSelector: 'span[data-valmsg-for="UserNewPasswordHash"]'
            });

        });
    </script>
}