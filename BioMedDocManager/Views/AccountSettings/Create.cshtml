@model BioMedDocManager.Models.CreateUserViewModel
@{
    ViewData["Title"] = Loc.T("AccountSettings.Create.Title");
    Layout = "_NoNavLayout";

    var deptItems = new SelectList(
        (IEnumerable<SelectOption>)ViewBag.DepartmentOptions,
        "OptionValue", "OptionText"
    );

    var policy = ViewBag.PasswordPolicy;
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-pencil-square me-2"></i>@ViewData["Title"]
    </h4>

    <form id="myForm"
          class="PasswordForm"
          method="post"
          action="@Url.Action("Create", "AccountSettings")"
          target="_top">

        @Html.AntiForgeryToken()

        <div class="pop">

            <!-- 帳號(工號) -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserAccount)</strong>
                </div>
                <div class="col-md-10">
                    @Html.TextBoxFor(m => m.UserAccount,
                    new { @class = "form-control", required = "required" })
                </div>
            </div>

            <!-- 姓名 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserFullName)</strong>
                </div>
                <div class="col-md-10">
                    @Html.TextBoxFor(m => m.UserFullName,
                                        new { @class = "form-control", required = "required" })
                </div>
            </div>

            <!-- 職稱 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserJobTitle)</strong>
                </div>
                <div class="col-md-10">
                    @Html.TextBoxFor(
                                        m => m.UserJobTitle,
                                        new
                                        {
                                            @class = "form-control",
                                            maxlength = "100",
                                            placeholder = Loc.T("User.UserJobTitle.Placeholder")
                                        })
                </div>
            </div>

            <!-- 部門 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.DepartmentId)</strong>
                </div>
                <div class="col-md-10">
                    @await Html.PartialAsync("_DepartmentSelect",
                                        Model.DepartmentId?.ToString(),
                                        new ViewDataDictionary(ViewData)
                                        {
                                            ["Options"] = ViewBag.DepartmentOptions,
                                            ["IsRequired"] = true,
                                            ["FieldName"] = "DepartmentId",
                                            ["LabelText"] = Loc.T("Common.PleaseSelect")
                                        })
                </div>
            </div>

            <!-- Email -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <span class="text-danger fw-bold">*</span>
                    <strong>@Html.LabelFor(m => m.UserEmail)</strong>
                </div>
                <div class="col-md-10">
                    @Html.TextBoxFor(
                                        m => m.UserEmail,
                                        new
                                        {
                                            @class = "form-control",
                                            type = "email",
                                            required = "required",
                                            maxlength = "255",
                                            placeholder = Loc.T("User.UserEmail.Placeholder")
                                        })
                    <span asp-validation-for="UserEmail" class="text-danger"></span>
                </div>
            </div>

            <!-- 市話 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserPhone)</strong>
                </div>
                <div class="col-md-10">
                    @Html.TextBoxFor(
                                        m => m.UserPhone,
                                        new
                                        {
                                            @class = "form-control",
                                            maxlength = "50",
                                            placeholder = Loc.T("User.UserPhone.Placeholder")
                                        })
                </div>
            </div>

            <!-- 手機 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserMobile)</strong>
                </div>
                <div class="col-md-10">
                    @Html.TextBoxFor(
                                        m => m.UserMobile,
                                        new
                                        {
                                            @class = "form-control",
                                            maxlength = "50",
                                            placeholder = Loc.T("User.UserMobile.Placeholder")
                                        })
                </div>
            </div>

            <!-- 密碼政策設定(供 JS 使用) -->
            <div id="passwordPolicyConfig"
                 data-enabled="@(policy?.Enabled == true ? "true" : "false")"
                 data-min-length="@(policy?.MinLength ?? 0)"
                 data-require-upper="@(policy?.RequireUpper == true ? "true" : "false")"
                 data-require-lower="@(policy?.RequireLower == true ? "true" : "false")"
                 data-require-digit="@(policy?.RequireDigit == true ? "true" : "false")"
                 data-require-special="@(policy?.RequireSpecial == true ? "true" : "false")"
                 data-special-chars="@((string)(policy?.SpecialCharSets ?? ""))"
                 class="d-none">
            </div>

            <!-- 密碼 -->
            <div class="row my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <span class="text-danger fw-bold">*</span><strong>@Html.LabelFor(m => m.UserPasswordHash)</strong>
                </div>
                <div class="col-md-10">

                    <div class="input-group">
                        <input asp-for="UserPasswordHash"
                               class="form-control"
                               type="password"
                               required="required"
                               data-target="UserConfirmPasswordHash"
                               data-validation="UserPasswordHashValidation" />

                        <!-- 眼睛按鈕維持 data-id -->
                        <button class="btn btn-outline-secondary togglePasswordButton" data-id="UserPasswordHash" type="button">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>

                    <!-- 這個是「雙向驗證訊息」的顯示位置（由 data-validation 指定） -->
                    <span id="UserPasswordHashValidation" class="text-danger"></span>

                    @if (policy != null && policy.Enabled == true)
                    {
                        <div class="mb-1">
                            <div class="text-12 fw-bold">
                                @Loc.T("PasswordPolicy.Title")
                            </div>

                            <ul id="passwordRulesList" class="text-12 mb-0 ps-3">

                                <!-- 最小長度 -->
                                <li class="password-rule text-muted" data-rule="minLength">
                                    @Loc.T("PasswordPolicy.MinLength.Prefix")
                                    @policy.MinLength
                                    @Loc.T("PasswordPolicy.MinLength.Suffix")
                                </li>

                                <!-- 大寫字母 -->
                                @if (policy.RequireUpper == true)
                                {
                                    <li class="password-rule text-muted" data-rule="upper">
                                        @Loc.T("PasswordPolicy.RequireUpper.Text")
                                    </li>
                                }

                                <!-- 小寫字母 -->
                                @if (policy.RequireLower == true)
                                {
                                    <li class="password-rule text-muted" data-rule="lower">
                                        @Loc.T("PasswordPolicy.RequireLower.Text")
                                    </li>
                                }

                                <!-- 數字 -->
                                @if (policy.RequireDigit == true)
                                {
                                    <li class="password-rule text-muted" data-rule="digit">
                                        @Loc.T("PasswordPolicy.RequireDigit.Text")
                                    </li>
                                }

                                <!-- 特殊符號 -->
                                @if (policy.RequireSpecial == true)
                                {
                                    <li class="password-rule text-muted" data-rule="special">
                                        @Loc.T("PasswordPolicy.RequireSpecial.Prefix")
                                        @policy.SpecialCharSets
                                        @Loc.T("PasswordPolicy.RequireSpecial.Suffix")
                                    </li>
                                }

                            </ul>
                        </div>
                    }

                    <span asp-validation-for="UserPasswordHash" class="text-danger"></span>
                </div>
            </div>

            <!-- 確認密碼 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <span class="text-danger fw-bold">*</span><strong>@Html.LabelFor(m => m.UserConfirmPasswordHash)</strong>
                </div>
                <div class="col-md-10">

                    <div class="input-group">
                        <input asp-for="UserConfirmPasswordHash"
                               class="form-control"
                               type="password"
                               required="required"
                               data-target="UserPasswordHash"
                               data-validation="UserConfirmPasswordHashValidation" />

                        <!-- 眼睛按鈕維持 data-id -->
                        <button class="btn btn-outline-secondary togglePasswordButton" data-id="UserConfirmPasswordHash" type="button">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>

                    <!-- 這個是「雙向驗證訊息」的顯示位置（由 data-validation 指定） -->
                    <span id="UserConfirmPasswordHashValidation" class="text-danger"></span>

                    <span asp-validation-for="UserConfirmPasswordHash" class="text-danger"></span>
                </div>
            </div>

            <!-- 使用者是否啟用 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserIsActive)</strong>
                </div>
                <div class="col-md-10">
                    @Html.DropDownListFor(
                    m => m.UserIsActive,
                                        new List<SelectListItem>
                                        {
                                        new() { Text = Loc.T("Common.Enabled"),  Value = "true" },
                                        new() { Text = Loc.T("Common.Disabled"), Value = "false" }
                                        },
                                        new { @class = "form-select" })
                </div>
            </div>

            <!-- 是否鎖定 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserIsLocked)</strong>
                </div>
                <div class="col-md-10">
                    @Html.DropDownListFor(
                                        m => m.UserIsLocked,
                                        new List<SelectListItem>
                                        {
                                        new() { Text = Loc.T("Common.Unlocked"), Value = "false" },
                                        new() { Text = Loc.T("Common.Locked"),   Value = "true" }
                                        },
                                        new { @class = "form-select" })
                </div>
            </div>

            <!-- 備註 -->
            <div class="row align-items-center my-3">
                <div class="col-md-2 col-form-label text-md-end text-start">
                    <strong>@Html.LabelFor(m => m.UserRemarks)</strong>
                </div>
                <div class="col-md-10">
                    @Html.TextAreaFor(
                                        m => m.UserRemarks,
                                        4, 50,
                                        new
                                        {
                                            @class = "form-control",
                                            maxlength = "255",
                                            placeholder = Loc.T("User.UserRemarks.Placeholder")
                                        })
                </div>
            </div>

            <!-- 按鈕 -->
            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    <button type="submit"
                            class="btn2 btn-success mt-2 col-6 col-md-3 mx-1">
                        <i class="fas fa-check-circle"></i> @Loc.T("Common.Save")
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">
        $(function () {
            // 確認密碼
            CheckConfirmPassword();

            // 密碼顯示/隱藏（眼睛按鈕）
            passwordVisibilityListener();

            // 動態顯示已完成的密碼規則
            bindPasswordPolicyWatcher({
                configSelector: '#passwordPolicyConfig',
                rulesListSelector: '#passwordRulesList',
                inputSelector: '#UserPasswordHash',
                formSelector: '.PasswordForm',
                errorSelector: 'span[data-valmsg-for="UserPasswordHash"]'
            });
        });
    </script>
}