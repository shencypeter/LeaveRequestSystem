@using System.Text.Json
@using BioMedDocManager.Extensions
@using BioMedDocManager.Models
@model IEnumerable<Dictionary<string, object>>

@{
    ViewData["Title"] = Loc.T("User.UserAccount");
    Layout = "_AssetLayout";

    // 角色
    var allRoles = ViewData["AllRoles"] as List<Role> ?? new();
    allRoles = allRoles.OrderBy(r => r.RoleGroup).ToList();
    var half = (int)Math.Ceiling(allRoles.Count / 2.0);
    var leftRoles = allRoles.Take(half).ToList();
    var rightRoles = allRoles.Skip(half).ToList();
    int roleIndex = 0;

    var queryModel = QueryableExtensions.GetSessionQueryModel<AccountViewModel>(Context);
    queryModel.OrderBy ??= "UserId";
    queryModel.SortDir ??= "asc";

    var headers = ViewData["tableHeaders"] as Dictionary<string, string> ?? new();
}

<form method="post" id="myForm">
    @Html.AntiForgeryToken()

    <div class="accordion" id="queryAccordion">
        <div class="accordion-item border border-secondary-subtle bg-light">
            <h2 class="accordion-header" id="userHeading">
                <button class="accordion-button collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#userCollapse"
                        aria-expanded="false"
                        aria-controls="userCollapse">
                    <i class="fa fa-user me-2"></i> @ViewData["Title"]
                </button>
            </h2>

            <div id="userCollapse"
                 class="accordion-collapse collapse show"
                 aria-labelledby="userHeading"
                 data-bs-parent="#queryAccordion">
                <div class="accordion-body mx-3">

                    <!-- Row 1：帳號 / 姓名 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("User.UserAccount")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           name="@nameof(AccountViewModel.UserAccount)"
                                           value="@queryModel.UserAccount" />
                                </div>
                            </div>
                        </div>

                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("User.UserFullName")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           name="@nameof(AccountViewModel.UserFullName)"
                                           value="@queryModel.UserFullName" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2：是否啟用 / 角色 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-start">
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("User.UserIsActive")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    @await Html.PartialAsync("_BoolNullableSelect", new BoolNullableSelectVm
                                    {
                                        Id = "UserIsActive",
                                                                        Name = nameof(AccountViewModel.UserIsActive),
                                                                        Value = queryModel.UserIsActive
                                                                        })
                                </div>
                            </div>
                        </div>

                        <div class="col">
                            <div class="row g-2 align-items-start">
                                <label class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("User.RoleCodeList")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <div class="row row-cols-1 row-cols-lg-2 g-2">
                                        <div class="col">
                                            @foreach (var role in leftRoles)
                                            {
                                                string checkboxId = $"role{roleIndex++}";
                                                bool isChecked = queryModel.RoleId?.Contains(role.RoleId) == true;
                                                <div class="form-check text-start">
                                                    <input class="form-check-input"
                                                           type="checkbox"
                                                           name="RoleId"
                                                           value="@role.RoleId"
                                                           id="@checkboxId"
                                                           @(isChecked ? "checked" : "") />
                                                    <label class="form-check-label" for="@checkboxId">
                                                        【@Loc.T($"Role.{role.RoleGroup}")】@Loc.T($"Role.{role.RoleCode}")
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                        <div class="col">
                                            @foreach (var role in rightRoles)
                                            {
                                                string checkboxId = $"role{roleIndex++}";
                                                bool isChecked = queryModel.RoleId?.Contains(role.RoleId) == true;
                                                <div class="form-check text-start">
                                                    <input class="form-check-input"
                                                           type="checkbox"
                                                           name="RoleId"
                                                           value="@role.RoleId"
                                                           id="@checkboxId"
                                                           @(isChecked ? "checked" : "") />
                                                    <label class="form-check-label" for="@checkboxId">
                                                        【@Loc.T($"Role.{role.RoleGroup}")】@Loc.T($"Role.{role.RoleCode}")
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center flex-wrap gap-2">
                            <button type="submit" class="btn2 btn-primary mt-2 search_btn">
                                <i class="fas fa-search"></i> @Loc.T("Common.Search")
                            </button>

                            <a id="create_btn" href="@Url.Action("Create")" class="btn2 btn-success mt-2">
                                <i class="fas fa-plus-circle"></i> @Loc.T("Common.Create")
                            </a>

                            <button type="button"
                                    class="btn2 btn-secondary mt-2 clear_btn"
                                    data-form="myForm">
                                <i class="fas fa-eraser"></i> @Loc.T("Common.Reset")
                            </button>
                        </div>
                    </div>

                    <!-- Hidden -->
                    <input type="hidden" name="@nameof(queryModel.OrderBy)" value="@queryModel.OrderBy" />
                    <input type="hidden" name="@nameof(queryModel.SortDir)" value="@queryModel.SortDir" />
                    <input type="hidden" name="@nameof(queryModel.PageSize)" value="@queryModel.PageSize" />
                    <input type="hidden" name="@nameof(queryModel.PageNumber)" value="@queryModel.PageNumber" />
                </div>
            </div>
        </div>
    </div>
</form>

<div class="table">
    <table class="table table-striped table-hover table-bordered text-break" id="myTable">
        <thead>
            <tr>
                @foreach (var item in headers)
                {
                    <th data-id="@item.Key">
                        @if (item.Key != "RowNum")
                        {
                            <a href="#"
                               title="@($"{Loc.T("Common.SortByColumn.Tooltip.Prefix")}{Loc.T(item.Value)}{Loc.T("Common.SortByColumn.Tooltip.Suffix")}")">
                                @Loc.T(item.Value)
                            </a>
                        }
                        else
                        {
                            @Loc.T(item.Value)
                        }
                    <span class="order-index">
                        @(queryModel.OrderBy?.EndsWith(item.Key) == true
                                                ? (queryModel.SortDir == "asc" ? "▲" : "▼")
                                                : "")
                    </span>
                </th>
                                }
                <th class="col-actions">@Loc.T("Common.Actions")</th>
            </tr>
        </thead>

        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(headers.Count + 1)">
                        @Loc.T("Common.NoData")
                    </td>
                </tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    <tr>
                        @foreach (var key in headers.Keys)
                        {
                            if (!row.TryGetValue(key, out var cell)) { cell = ""; }
                            string value = TableHelper.FormatValue(cell, Loc);

                            <td class="@(value == "(" + Loc.T("Common.None") + ")" ? "none-data" : "")">
                                @Html.Raw(value)
                            </td>
                        }

                        <td class="col-actions">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle"
                                        type="button"
                                        data-bs-toggle="dropdown">
                                    @Loc.T("Common.Actions")
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item detail" href="@Url.Action("Details", new { id = row["UserId"] })">@Loc.T("Common.View")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Edit", new { id = row["UserId"] })">@Loc.T("Common.Edit")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("EditGroup", new { id = row["UserId"] })">@Loc.T("User.UserGroupList")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("ResetPassword", new { id = row["UserId"] })">@Loc.T("AppAction.ResetPassword")</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_PagerSection", queryModel)
