@using System.Text.Json
@using BioMedDocManager.Extensions
@model IEnumerable<Dictionary<string,object>>
@{
    ViewData["Title"] = "帳號設定";
    Layout = "_AssetLayout";

    // 角色
    var allRoles = ViewData["AllRoles"] as List<Role> ?? new List<Role>() { };
    allRoles = allRoles.OrderBy(s => s.RoleGroup).ToList();
    int total = allRoles.Count;// 所有角色總數
    var half = (int)Math.Ceiling(allRoles.Count / 2.0);
    var leftRoles = allRoles.Take(half).ToList();
    var rightRoles = allRoles.Skip(half).ToList();
    int roleIndex = 0;

    var queryModel = QueryableExtensions.GetSessionQueryModel<AccountViewModel>(Context);
    queryModel.OrderBy ??= "id";
    queryModel.SortDir ??= "asc";

    var headers = ViewData["tableHeaders"] as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<form method="post" id="myForm">
    @Html.AntiForgeryToken()

    <div class="accordion" id="queryAccordion">
        <!-- 使用者帳號設定 -->
        <div class="accordion-item border border-secondary-subtle bg-light">
            <h2 class="accordion-header" id="userHeading">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#userCollapse" aria-expanded="false" aria-controls="userCollapse">
                    <i class="fa fa-user me-2"></i> 使用者帳號設定
                </button>
            </h2>
            <div id="userCollapse" class="accordion-collapse collapse show" aria-labelledby="userHeading"
                 data-bs-parent="#queryAccordion">
                <div class="accordion-body mx-3">

                    <!-- Row 1: 使用者工號 / 使用者姓名 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">

                        <!-- 組1(佔 col-md-6)：工號 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="UserName" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    使用者工號：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text" class="form-control" id="UserName"
                                           name="@nameof(AccountViewModel.UserAccount)"
                                           value="@queryModel.UserAccount" placeholder="請輸入工號" />
                                </div>
                            </div>
                        </div>

                        <!-- 組2(佔 col-md-6)：姓名 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="FullName" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    使用者姓名：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text" class="form-control" id="FullName"
                                           name="@nameof(AccountViewModel.UserFullName)"
                                           value="@queryModel.UserFullName" placeholder="請輸入姓名" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: 是否啟用 / 系統角色 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-start">

                        <!-- 組1：是否啟用 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="IsActive" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    是否啟用：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <select id="IsActive" name="IsActive" class="form-select">
                                        <option value="" selected=@(queryModel.UserIsActive == null)>全部顯示</option>
                                        <option value="true" selected=@(queryModel.UserIsActive == true)>啟用</option>
                                        <option value="false" selected=@(queryModel.UserIsActive == false)>停用</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- 組2：系統角色 -->
                        <div class="col">
                            <div class="row g-2 align-items-start">
                                <label for="DocControlRole" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    角色權限：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <!-- 內部再切左右兩欄清單；在窄螢幕會變成單欄 -->
                                    <div class="row row-cols-1 row-cols-lg-2 g-2">
                                        <div class="col">
                                            @foreach (var role in leftRoles)
                                            {
                                                string checkboxId = $"role{roleIndex++}";
                                                bool isChecked = queryModel.RoleId != null && queryModel.RoleId.Contains(role.RoleId);
                                                <div class="form-check text-start">
                                                    <input class="form-check-input" type="checkbox" name="RoleId"
                                                           value="@role.RoleId" id="@checkboxId" @(isChecked ? "checked" : "") />
                                                    <label class="form-check-label" for="@checkboxId">【@role.RoleGroup】@role.RoleName</label>
                                                </div>
                                            }
                                        </div>
                                        <div class="col">
                                            @foreach (var role in rightRoles)
                                            {
                                                string checkboxId = $"role{roleIndex++}";
                                                bool isChecked = queryModel.RoleId != null && queryModel.RoleId.Contains(role.RoleId);
                                                <div class="form-check text-start">
                                                    <input class="form-check-input" type="checkbox" name="RoleId"
                                                           value="@role.RoleId" id="@checkboxId" @(isChecked ? "checked" : "") />
                                                    <label class="form-check-label" for="@checkboxId">【@role.RoleGroup】@role.RoleName</label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 按鈕排 -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center flex-wrap gap-2">

                            <button type="submit" class="btn2 btn-primary mt-2 search_btn">
                                <i class="fas fa-search"></i>&ensp;查詢
                            </button>

                            <a id="create_btn" href="@Url.Action("Create")"
                               class="btn2 btn-success mt-2">
                                <i class="fas fa-user-plus"></i>&ensp;建立
                            </a>

                            <button type="button" class="btn2 btn-secondary mt-2 clear_btn" data-form="myForm">
                                <i class="fas fa-eraser"></i> 清除
                            </button>

                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden" id="@(nameof(queryModel.OrderBy))" name="@nameof(queryModel.OrderBy)" value="@queryModel.OrderBy" />
                    <input type="hidden" id="@(nameof(queryModel.SortDir))" name="@nameof(queryModel.SortDir)" value="@queryModel.SortDir" />
                    <input type="hidden" id="@nameof(queryModel.PageSize)" name="@nameof(queryModel.PageSize)" value="@queryModel.PageSize" />
                    <input type="hidden" id="@nameof(queryModel.PageNumber)" name="@nameof(queryModel.PageNumber)" value="@queryModel.PageNumber" />
                </div>
            </div>
        </div>
    </div>
</form>



<div class="table">
    <table class="table table-striped table-hover table-bordered text-break" id="myTable">
        <thead>
            <tr>
                @foreach (var item in headers)
                {
                    <th data-id="@item.Key">
                        @if (item.Key != "RowNum")
                        {
                            <a href="#" title="點選「@(item.Value)」欄位進行排序"> @item.Value </a>
                        }
                        else
                        {
                            @item.Value
                        }
                        <span class="order-index"> @(queryModel.OrderBy.EndsWith(item.Key) ? (queryModel.SortDir == "asc" ? "▲" : "▼") : "")</span>
                    </th>
                }
                <th class="col-actions">功能</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(headers.Count + 1)">查無資料</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    <tr>
                        @foreach (var key in headers.Keys)  @* 依表頭順序取值 *@
                        {
                            if (!row.TryGetValue(key, out var cell)) { cell = ""; }

                            string value = TableHelper.FormatValue(cell);

                            <td class="@(value == "(無)" ? "none-data" : "") @((key.Equals("RowNum", StringComparison.OrdinalIgnoreCase)) ? "text-nowrap" : "")">
                                @Html.Raw(value)
                            </td>
                        }

                        <td class="col-actions">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    功能
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item detail" href="@Url.Action("Details", "AccountSettings", new { UserId = row["UserId"] })">檢視</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Edit", "AccountSettings", new { UserId = row["UserId"] })">編輯</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("EditGroup", "AccountSettings", new { UserId = row["UserId"] })">編輯【群組】</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("ResetPassword", "AccountSettings", new { UserId = row["UserId"] })">重設密碼</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>

    </table>
</div>

@await Html.PartialAsync("_PagerSection", queryModel)

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">

    </script>
}