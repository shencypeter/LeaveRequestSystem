@model BioMedDocManager.Models.Role
@using BioMedDocManager.Models

@{
    ViewData["Title"] = Loc.T("Role.Delete.Title");
    Layout = "_NoNavLayout";

    var userList = ViewBag.UserUsageList as List<RoleUsageUserViewModel> ?? new();
    var groupList = ViewBag.GroupUsageList as List<RoleUsageGroupViewModel> ?? new();

    int userUsageCount = userList.Count;
    int groupUsageCount = groupList.Count;

    bool hasUsage = ViewBag.HasUsage ?? false;

    // 權限明細（RolePermissions + Resource + AppAction）
    var permList = ViewBag.RolePermissions as IEnumerable<RolePermission>
                   ?? Enumerable.Empty<RolePermission>();

    // 依 Resource 分組（顯示名稱當 key）
    var groupedPerms = permList
        .Where(p => p.Resource != null && p.AppAction != null)
        .GroupBy(p => new
        {
            p.Resource!.ResourceId,
            p.Resource!.ResourceKey
        })
        .OrderBy(g => g.Key.ResourceKey)
        .ToList();
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-trash me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Delete"
          asp-route-roleId="@Model.RoleId"
          method="post"
          id="myForm"
          target="_top">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RoleId" />

        <div class="pop">

            <!-- 基本資訊 -->
            <div class="row align-items-center my-2">
                <label asp-for="RoleGroup" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.RoleGroup (@Loc.T($"Role.{Model.RoleGroup}"))</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="RoleCode" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.RoleCode (@Loc.T($"Role.{Model.RoleCode}"))</p>
                </div>
            </div>

            @* 有使用才顯示使用者/群組明細 *@
            @if (hasUsage)
            {
                <!-- 使用狀況 -->
                <div class="row align-items-start my-3">
                    <label class="col-md-2 col-form-label text-md-end">
                        @Loc.T("UserDetails.EffectiveRoles")
                    </label>
                    <div class="col-md-10">

                        <!-- 使用者明細UserRoles -->
                        @if (userUsageCount > 0)
                        {
                            <div class="col-md-12 col-form-label mb-3">
                                <h6>
                                    @Loc.T("Role.Delete.UserUsageCount.Prefix")
                                    @userUsageCount
                                    @Loc.T("Role.Delete.UserUsageCount.Suffix")
                                </h6>
                                <ul>
                                    @foreach (var u in userList)
                                    {
                                        <li>@u.UserAccount (@u.UserFullName)</li>
                                    }
                                </ul>
                            </div>
                        }

                        <!-- 群組明細UserGroupRoles -->
                        @if (groupUsageCount > 0)
                        {
                            <div class="col-md-12 col-form-label">
                                <h6>
                                    @Loc.T("Role.Delete.GroupUsageCount.Prefix")
                                    @groupUsageCount
                                    @Loc.T("Role.Delete.GroupUsageCount.Suffix")
                                </h6>
                                <ul>
                                    @foreach (var g in groupList)
                                    {
                                        <li>
                                            @g.UserGroupCode
                                            @if (!string.IsNullOrWhiteSpace(g.UserGroupDescription))
                                            {
                                                <span class="text-muted"> - @g.UserGroupDescription</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- 權限明細：Resource × Action badge（無論有沒有被使用者/群組引用都顯示） -->
            <div class="row align-items-start my-3">
                <label class="col-md-2 col-form-label text-md-end">
                    @Loc.T("UserDetails.EffectivePermissions")
                </label>
                <div class="col-md-10" id="effectivePermissionsContainer">
                    @if (!groupedPerms.Any())
                    {
                        <div class="text-muted">@Loc.T("Role.NoPermissions")</div>
                    }
                    else
                    {
                        @* 每個 Resource 一塊 *@
                        @foreach (var g in groupedPerms)
                        {
                            <div class="mb-3">
                                <h6 class="mb-1">@Loc.T($"{g.Key.ResourceKey}.Index.Title")</h6>
                                <div>
                                    @foreach (var p in g.OrderBy(x => x.AppAction!.AppActionOrder)
                                                                .ThenBy(x => x.AppAction!.AppActionCode))
                                    {
                                        <span class="badge bg-success me-1 mb-1"
                                              title="@p.AppAction!.AppActionCode">
                                            @Loc.T($"AppAction.{p.AppAction!.AppActionCode}")
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            @* 刪除提示（依 hasUsage 顯示不同訊息） *@
            @if (hasUsage)
            {
                <div class="alert alert-danger mb-0">
                    @Html.Raw(Loc.T("Role.Delete.CannotDeleteMsg"))
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    @Loc.T("Common.ConfirmDelete") <strong>@Model.RoleCode</strong> ?<br />
                    @Loc.T("Role.Delete.PermissionWarning")
                </div>

                <!-- 按鈕 -->
                <div class="row align-items-center my-3">
                    <div class="col-12 d-flex flex-wrap justify-content-center">
                        <button type="submit"
                                class="btn2 btn-danger mt-2 col-6 col-md-3 mx-1">
                            <i class="bi bi-trash"></i> @Loc.T("Common.Delete")
                        </button>
                    </div>
                </div>
            }
        </div>
    </form>
</div>
