@using BioMedDocManager.Extensions
@using BioMedDocManager.Models
@model IEnumerable<Dictionary<string, object>>

@{
    ViewData["Title"] = "角色管理";
    Layout = "_AssetLayout";

    var queryModel = QueryableExtensions.GetSessionQueryModel<RoleQueryViewModel>(Context);
    queryModel.OrderBy ??= "RoleGroup";
    queryModel.SortDir ??= "asc";

    var headers = ViewData["tableHeaders"] as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<form method="post" id="myForm">
    @Html.AntiForgeryToken()

    <div class="accordion" id="queryAccordion">
        <!-- ✅ 角色查詢條件 -->
        <div class="accordion-item border border-secondary-subtle bg-light">
            <h2 class="accordion-header" id="roleHeading">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#roleCollapse" aria-expanded="false" aria-controls="roleCollapse">
                    <i class="fa fa-id-badge me-2"></i> @ViewData["Title"]
                </button>
            </h2>
            <div id="roleCollapse" class="accordion-collapse collapse show" aria-labelledby="roleHeading"
                 data-bs-parent="#queryAccordion">
                <div class="accordion-body mx-3">

                    <!-- Row 1: 角色群組 / 角色名稱  -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">
                        <!-- 角色群組 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="RoleGroup" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    角色群組：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="RoleGroup"
                                           name="@nameof(RoleQueryViewModel.RoleGroup)"
                                           value="@queryModel.RoleGroup"
                                           placeholder="請輸入角色群組" />
                                </div>
                            </div>
                        </div>

                        <!-- 角色名稱 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="RoleName" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    角色名稱：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="RoleName"
                                           name="@nameof(RoleQueryViewModel.RoleName)"
                                           value="@queryModel.RoleName"
                                           placeholder="請輸入角色名稱" />
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- 按鈕排 -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center flex-wrap gap-2">
                            <button type="submit" class="btn2 btn-primary mt-2 search_btn">
                                <i class="fas fa-search"></i>&ensp;查詢
                            </button>

                            <a id="create_btn" href="@Url.Action("Create", "Role")"
                               class="btn2 btn-success mt-2">
                                <i class="fas fa-plus-circle"></i>&ensp;新增角色
                            </a>

                            <button type="button" class="btn2 btn-secondary mt-2 clear_btn" data-form="myForm">
                                 <i class="fas fa-eraser"></i> @Loc.T("Common.Reset")
                            </button>
                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden"
                           id="@nameof(queryModel.OrderBy)"
                           name="@nameof(queryModel.OrderBy)"
                           value="@queryModel.OrderBy" />
                    <input type="hidden"
                           id="@nameof(queryModel.SortDir)"
                           name="@nameof(queryModel.SortDir)"
                           value="@queryModel.SortDir" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageSize)"
                           name="@nameof(queryModel.PageSize)"
                           value="@queryModel.PageSize" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageNumber)"
                           name="@nameof(queryModel.PageNumber)"
                           value="@queryModel.PageNumber" />
                </div>
            </div>
        </div>
    </div>
</form>

<div class="table">
    <table class="table table-striped table-hover table-bordered text-break" id="myTable">
        <thead>
            <tr>
                @foreach (var item in headers)
                {
                    <th data-id="@item.Key">
                        @if (!string.Equals(item.Key, "RowNum", StringComparison.OrdinalIgnoreCase))
                        {
                            <a href="#" title="點選「@(item.Value)」欄位進行排序">@item.Value</a>
                        }
                        else
                        {
                            @item.Value
                        }
                    <span class="order-index">
                        @(queryModel.OrderBy?.EndsWith(item.Key) == true
                                                ? (queryModel.SortDir == "asc" ? "▲" : "▼")
                                                : "")
                    </span>
                </th>
                                }
                <th class="col-actions">功能</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(headers.Count + 1)">查無資料</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    <tr>
                        @foreach (var key in headers.Keys)  @* 依表頭順序取值 *@
                        {
                            if (!row.TryGetValue(key, out var cell)) { cell = ""; }

                            string value =TableHelper.FormatValue(cell, Loc);

                            <td class="@(value == "(" + Loc.T("Common.None") + ")" ? "none-data" : "") @((key.Equals("RowNum", StringComparison.OrdinalIgnoreCase)) ? "text-nowrap" : "")">
                                @Html.Raw(value)
                            </td>
                        }

                        <td class="col-actions">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    功能
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item detail" href="@Url.Action("Details", "Role", new { id = row["RoleId"] })">檢視</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Edit", "Role", new { id = row["RoleId"] })">編輯</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Edit", "RolePermission", new { id = row["RoleId"] })">編輯【權限】</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Delete", "Role", new { id = row["RoleId"] })">刪除</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_PagerSection", queryModel)

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">

    </script>
}
