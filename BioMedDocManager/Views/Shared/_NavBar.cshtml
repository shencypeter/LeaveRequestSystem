@using System.Linq
@using System.Collections.Generic
@using BioMedDocManager.Models

@{
    var UserFullName = ViewData["UserFullName"]?.ToString() ?? "訪客";
    var greeting = ViewData["Greeting"]?.ToString() ?? "";

    // 共用的 MenuTree（跟 _BannerMenu 一樣）
    var menuTree = ViewData["MenuTree"] as List<MenuItemGroupViewModel> ?? new();

    // 目前所在 controller
    var routeController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty)
        .ToLowerInvariant();

    // 判斷目前所在的群組（用 child.Resource.ResourceKey 對 controller）
    MenuItemGroupViewModel? currentGroup = null;

    if (!string.IsNullOrEmpty(routeController) &&
        !string.Equals(routeController, "home", StringComparison.OrdinalIgnoreCase))
    {
        currentGroup = menuTree.FirstOrDefault(g =>
            // 若未來 parent 也綁 Resource，就一起比對
            (g.Parent?.Resource?.ResourceKey ?? string.Empty)
                .Equals(routeController, StringComparison.OrdinalIgnoreCase)
            ||
            g.Children.Any(c =>
                (c.Resource?.ResourceKey ?? string.Empty)
                    .Equals(routeController, StringComparison.OrdinalIgnoreCase))
        );
    }

    var hasMenu = menuTree.Any();

    var TwoFA_ENABLED = bool.Parse(ViewData["2FA_ENABLED"].ToString());
}

<nav class="navbar sticky-top navbar-dark text-light">
    <div class="container-fluid">
        <div class="justify-content-start">
            &ensp;
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas"
                    data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand fw-bolder align-middle" href="~/">
                &ensp;文管與電子採購系統(範例)
            </a>
        </div>

        <div class="justify-content-end user-nav">
            <i class="fa-solid fa-user"></i>
            <span class="ps-1" id="memberNo">@UserFullName</span>
            <span>，@greeting！&ensp;&ensp;</span>
            @if (UserFullName == "訪客")
            {
                <a class="btn btn-link px-1 me-3 py-1 logout" href="@Url.Action("Index", "Login")">登入</a>
            }
            else
            {
                <a class="btn btn-link px-1 me-3 py-1 logout change_password_btn" href="@Url.Action("ChangePassword", "AccountSettings")" target="_blank">更改密碼</a>
                @if (TwoFA_ENABLED)
                {
                    <a class="btn btn-link px-1 me-3 py-1 logout register_totp_btn" href="@Url.Action("RegisterTotp", "AccountSettings")" target="_blank">註冊TOTP</a>
                }
                <a class="btn btn-link px-1 me-3 py-1 logout" href="@Url.Action("Logout", "Login")">登出</a>
            }
            
            @await Html.PartialAsync("_Language")
        </div>

        <div class="offcanvas offcanvas-start navbar-dark text-light" tabindex="-1"
             id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
            <div class="offcanvas-header justify-content-center mt-4">
                <span class="offcanvas-title fw-bolder align-middle fs-5" id="offcanvasNavbarLabel">
                    <i class="fa-solid fa-user"></i>
                    <span class="ps-1" id="memberNo">@UserFullName</span>
                    <span>，@greeting！&ensp;&ensp;</span>
                </span>
            </div>
            <hr class="my-0 bg-white w-100" />
            <div class="offcanvas-body">
                <ul class="navbar-nav justify-content-start flex-grow-1 fw-bold fs-5">

                    @* === 沒有 Menu（未登入或沒權限） === *@
                    @if (!hasMenu)
                    {
                        if (UserFullName == "訪客")
                        {
                            <li class="nav-item py-1 px-5">
                                <a class="nav-link active text-decoration" href="@Url.Action("Login", "Login")">登入</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item py-1 px-5">
                                <span class="nav-link active text-decoration">
                                    您的帳號尚未開通使用權限，請聯絡系統管理員
                                </span>
                            </li>
                            <li class="nav-item py-1 px-5">
                                <a class="nav-link active text-decoration" href="@Url.Action("Logout", "Login")">登出</a>
                            </li>
                        }
                    }
                    else
                    {
                        @* === 第一層：顯示所有父層主選單（跟 _BannerMenu root 模式一致） === *@
                        if (currentGroup == null)
                        {
                            foreach (var group in menuTree
                            .OrderBy(g => g.Parent?.MenuItemDisplayOrder ?? int.MaxValue)
                            .ThenBy(g => g.Parent?.MenuItemId ?? int.MaxValue))
                            {
                                var parent = group.Parent;
                                if (parent == null)
                                {
                                    continue;
                                }

                                var label = parent.MenuItemTitle ?? "(未命名選單)";
                                var iconClass = parent.MenuItemIcon;

                                // Parent 不直接對應 controller，讓它連到第一個子項
                                var firstChild = group.Children
                                .OrderBy(c => c.MenuItemDisplayOrder)
                                .ThenBy(c => c.MenuItemId)
                                .FirstOrDefault();

                                string url = "#";
                                if (firstChild?.Resource?.ResourceKey is string childKey &&
                                !string.IsNullOrWhiteSpace(childKey))
                                {
                                    url = Url.Action("Index", childKey);
                                }

                                <li class="nav-item py-1 px-5">
                                    <a class="nav-link active text-decoration" href="@url">
                                        @if (!string.IsNullOrWhiteSpace(iconClass))
                                        {
                                            <i class="@iconClass me-1"></i>
                                        }
                                        @label
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            @* === 第二層：顯示 currentGroup 底下的所有子選單 === *@
                            <li class="nav-item py-1 px-5">
                                <a class="nav-link active text-decoration" href="~/">
                                    <i class="fa fa-arrow-left"></i> 返回上層
                                </a>
                            </li>

                            @foreach (var child in currentGroup.Children
                                                .OrderBy(c => c.MenuItemDisplayOrder)
                                                .ThenBy(c => c.MenuItemId))
                            {
                                var label = child.MenuItemTitle ?? "(未命名)";
                                var iconClass = child.MenuItemIcon;

                                string url = "#";
                                if (child.Resource?.ResourceKey is string childKey &&
                                !string.IsNullOrWhiteSpace(childKey))
                                {
                                    url = Url.Action("Index", childKey);
                                }

                                var childCtrl = (child.Resource?.ResourceKey ?? string.Empty).ToLowerInvariant();
                                var isActiveChild =
                                !string.IsNullOrEmpty(childCtrl) &&
                                string.Equals(childCtrl, routeController, StringComparison.OrdinalIgnoreCase);

                                var linkCls = "nav-link text-decoration" + (isActiveChild ? " active" : string.Empty);

                                <li class="nav-item py-1 px-5">
                                    <a class="@linkCls" href="@url">
                                        @if (!string.IsNullOrWhiteSpace(iconClass))
                                        {
                                            <i class="@iconClass me-1"></i>
                                        }
                                        @label
                                    </a>
                                </li>
                            }
                        }

                        @* === 最下面照舊放登入 / 登出 / 更改密碼 === *@
                        <li class="nav-item py-1 px-5 mt-3">
                            <hr class="my-2 bg-white" />
                        </li>

                        @if (UserFullName == "訪客")
                        {
                            <li class="nav-item py-1 px-5">
                                <a class="nav-link active text-decoration" href="@Url.Action("Login", "Login")">登入</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item py-1 px-5">
                                <a class="nav-link active text-decoration change_password_btn" href="@Url.Action("ChangePassword", "AccountSettings")" target="_blank">更改密碼</a>
                            </li>

                            <li class="nav-item py-1 px-5">
                                <a class="nav-link active text-decoration register_totp_btn" href="@Url.Action("RegisterTotp", "AccountSettings")" target="_blank">註冊TOTP</a>
                            </li>


                            <li class="nav-item py-1 px-5">
                                <a class="nav-link active text-decoration" href="@Url.Action("Logout", "Login")">登出</a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</nav>
