@model string
@using BioMedDocManager.Models

@{
    var options = ViewData["Options"] as SelectOption[] ?? Array.Empty<SelectOption>();
    var isRequired = ViewData["IsRequired"] as bool? ?? false;
    var fieldName = ViewData["FieldName"] as string ?? "Id";

    // ❗不要在 Partial 裡硬塞中文
    var labelText = ViewData["LabelText"] as string ?? string.Empty;
}

<select id="@fieldName"
        name="@fieldName"
        class="form-select"
        @(isRequired ? "required" : "")>
    <option value="">@labelText</option>
    @foreach (var opt in options)
    {
        <option value="@opt.OptionValue"
                selected="@(opt.OptionValue == Model?.Trim() ? "selected" : null)">
            @opt.OptionText
        </option>
    }
</select>
