@model IEnumerable<Dictionary<string, object>>

@{
    ViewData["Title"] = Loc.T("Parameter.Index.Title");
    Layout = "_AssetLayout";

    var queryModel = QueryableExtensions.GetSessionQueryModel<ParameterQueryViewModel>(Context);
    queryModel.OrderBy ??= "Code";
    queryModel.SortDir ??= "asc";

    var headers = ViewData["tableHeaders"] as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<form method="post" id="myForm">
    @Html.AntiForgeryToken()

    <div class="accordion" id="queryAccordion">
        <div class="accordion-item border border-secondary-subtle bg-light">
            <h2 class="accordion-header" id="parameterHeading">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#parameterCollapse" aria-expanded="false" aria-controls="parameterCollapse">
                    <i class="fa fa-sliders me-2"></i> @ViewData["Title"]
                </button>
            </h2>

            <div id="parameterCollapse" class="accordion-collapse collapse show" aria-labelledby="parameterHeading"
                 data-bs-parent="#queryAccordion">
                <div class="accordion-body mx-3">

                    <!-- Row 1: 參數代碼 / 參數名稱 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">

                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="Code" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("Parameter.ParameterCode")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="Code"
                                           name="@nameof(ParameterQueryViewModel.ParameterCode)"
                                           value="@queryModel.ParameterCode"
                                           placeholder="@Loc.T("Parameter.ParameterCode.Placeholder")" />
                                </div>
                            </div>
                        </div>

                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="Name" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("Parameter.ParameterName")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="Name"
                                           name="@nameof(ParameterQueryViewModel.ParameterName)"
                                           value="@queryModel.ParameterName"
                                           placeholder="@Loc.T("Parameter.ParameterName.Placeholder")" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: 參數格式 / 是否啟用 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">

                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="Format" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("Parameter.ParameterFormat")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="Format"
                                           name="@nameof(ParameterQueryViewModel.ParameterFormat)"
                                           value="@queryModel.ParameterFormat"
                                           placeholder="@Loc.T("Parameter.ParameterFormat.Placeholder")" />
                                </div>
                            </div>
                        </div>

                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="IsActive" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("Parameter.ParameterIsActive")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <select id="IsActive"
                                            name="@nameof(ParameterQueryViewModel.ParameterIsActive)"
                                            class="form-select">
                                        <option value="" selected="@(queryModel.ParameterIsActive == null ? "selected" : null)">@Loc.T("Common.All")</option>
                                        <option value="true" selected="@(queryModel.ParameterIsActive == true ? "selected" : null)">@Loc.T("Common.Enabled")</option>
                                        <option value="false" selected="@(queryModel.ParameterIsActive == false ? "selected" : null)">@Loc.T("Common.Disabled")</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 按鈕排 -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center flex-wrap gap-2">

                            <button type="submit" class="btn2 btn-primary mt-2 search_btn">
                                <i class="fas fa-search"></i> @Loc.T("Common.Search")
                            </button>

                            <a id="create_btn" href="@Url.Action("Create", "Parameter")"
                               class="btn2 btn-success mt-2">
                                <i class="fas fa-plus-circle"></i> @Loc.T("Common.Create")
                            </a>

                            <button type="button" class="btn2 btn-secondary mt-2 clear_btn" data-form="myForm">
                                <i class="fas fa-eraser"></i> @Loc.T("Common.Reset")
                            </button>
                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden" id="@nameof(queryModel.OrderBy)" name="@nameof(queryModel.OrderBy)" value="@queryModel.OrderBy" />
                    <input type="hidden" id="@nameof(queryModel.SortDir)" name="@nameof(queryModel.SortDir)" value="@queryModel.SortDir" />
                    <input type="hidden" id="@nameof(queryModel.PageSize)" name="@nameof(queryModel.PageSize)" value="@queryModel.PageSize" />
                    <input type="hidden" id="@nameof(queryModel.PageNumber)" name="@nameof(queryModel.PageNumber)" value="@queryModel.PageNumber" />
                </div>
            </div>
        </div>
    </div>
</form>

<div class="table">
    <table class="table table-striped table-hover table-bordered text-break" id="myTable">
        <thead>
            <tr>
                @foreach (var item in headers)
                {
                    <th data-id="@item.Key">
                        @if (item.Key != "RowNum")
                        {
                            <a href="#" title="@($"{Loc.T("Common.SortByColumn.TooltipPrefix")}{Loc.T(item.Value)}{Loc.T("Common.SortByColumn.TooltipSuffix")}")"> @Loc.T(@item.Value)</a>
                        }
                        else
                        {
                            @Loc.T(item.Value)
                        }

                    <span class="order-index">
                        @(queryModel.OrderBy?.EndsWith(item.Key) == true
                                                ? (queryModel.SortDir == "asc" ? "▲" : "▼")
                                                : "")
                    </span>
                </th>
                                }
                <th class="col-actions">@Loc.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(headers.Count + 1)">@Loc.T("Common.NoData")</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    <tr>
                        @foreach (var key in headers.Keys)
                        {
                            if (!row.TryGetValue(key, out var cell)) { cell = ""; }
                            string value = TableHelper.FormatValue(cell, Loc);

                            <td class="@(value == "(" + Loc.T("Common.None") + ")" ? "none-data" : "") @((key.Equals("RowNum", StringComparison.OrdinalIgnoreCase)) ? "text-nowrap" : "")">
                                @Html.Raw(value)
                            </td>
                        }

                        <td class="col-actions">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @Loc.T("Common.Actions")
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item detail" href="@Url.Action("Details", "Parameter", new { id = row["ParameterId"] })">@Loc.T("Common.View")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Edit", "Parameter", new { id = row["ParameterId"] })">@Loc.T("Common.Edit")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Delete", "Parameter", new { id = row["ParameterId"] })">@Loc.T("Common.Delete")</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_PagerSection", queryModel)

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">
    </script>
}
