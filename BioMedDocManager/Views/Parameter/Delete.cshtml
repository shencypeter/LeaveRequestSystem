@model BioMedDocManager.Models.Parameter

@{
    ViewData["Title"] = "系統參數管理-刪除";
    Layout = "_NoNavLayout";
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Delete"
          asp-route-id="@Model.ParameterId"
          method="post"
          id="myForm"
          target="_top">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ParameterId" />

        <div class="pop">

            <div class="row align-items-center my-2">
                <label asp-for="ParameterCode" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ParameterCode</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="ParameterName" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ParameterName</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="ParameterFormat" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ParameterFormat</p>
                </div>
            </div>

            <div class="row align-items-start my-2">
                <label asp-for="ParameterValue" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ParameterValue</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="ParameterIsActive" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ParameterIsActiveText</p>
                </div>
            </div>

            <div class="alert alert-warning mb-0">
                確定要刪除參數：
                <strong>@Model.ParameterCode (@Model.ParameterName)</strong> 嗎？
            </div>

            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    <button type="submit" class="btn2 btn-danger mt-2 col-6 col-md-3 mx-1">
                        <i class="bi bi-trash"></i> @Loc.T("Common.Delete")
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>
