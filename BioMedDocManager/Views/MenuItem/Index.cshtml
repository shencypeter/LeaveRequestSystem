@using BioMedDocManager.Extensions
@using BioMedDocManager.Models
@model IEnumerable<Dictionary<string, object>>

@{
    ViewData["Title"] = Loc.T("MenuItem.Index.Title");
    Layout = "_AssetLayout";

    var queryModel = QueryableExtensions.GetSessionQueryModel<MenuItemQueryViewModel>(Context);

    var headers = ViewData["tableHeaders"] as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<form method="post" id="myForm">
    @Html.AntiForgeryToken()

    <div class="accordion" id="queryAccordion">
        <!-- 選單項目查詢設定 -->
        <div class="accordion-item border border-secondary-subtle bg-light">
            <h2 class="accordion-header" id="menuItemHeading">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#menuItemCollapse" aria-expanded="false" aria-controls="menuItemCollapse">
                    <i class="fa fa-list-ul me-2"></i> @ViewData["Title"]
                </button>
            </h2>
            <div id="menuItemCollapse" class="accordion-collapse collapse show" aria-labelledby="menuItemHeading"
                 data-bs-parent="#queryAccordion">
                <div class="accordion-body mx-3">

                    <!-- Row 1: 選單標題 / 連結 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">

                        <!-- 組1：選單標題 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("MenuItem.MenuItemTitle")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           name="@nameof(MenuItemQueryViewModel.MenuItemTitle)"
                                           value="@queryModel.MenuItemTitle"
                                           placeholder="@Loc.T("MenuItem.MenuItemTitle.Placeholder")" />
                                </div>
                            </div>
                        </div>

                        <!-- 組2：連結 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("MenuItem.ResourceKey")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           name="@nameof(MenuItemQueryViewModel.ResourceKey)"
                                           value="@queryModel.ResourceKey"
                                           placeholder="@Loc.T("MenuItem.ResourceKey.Placeholder")" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: 是否啟用 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">

                        <!-- 組1：是否啟用 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("MenuItem.MenuItemIsActive")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    @await Html.PartialAsync("_BoolNullableSelect", new BoolNullableSelectVm
                                    {
                                        Id = "MenuItemIsActive",
                                                                        Name = nameof(MenuItemQueryViewModel.MenuItemIsActive),
                                                                        Value = queryModel.MenuItemIsActive
                                                                        })
                                </div>
                            </div>
                        </div>

                        <!-- 組2：保留（暫不使用，可日後擴充） -->
                        <div class="col">
                        </div>
                    </div>

                    <!-- 按鈕排 -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center flex-wrap gap-2">
                            <button type="submit" class="btn2 btn-primary mt-2 search_btn">
                                <i class="fas fa-search"></i> @Loc.T("Common.Search")
                            </button>

                            <a id="create_btn" href="@Url.Action("Create", "MenuItem")"
                               class="btn2 btn-success mt-2">
                                <i class="fas fa-plus-circle"></i> @Loc.T("Common.Create")
                            </a>

                            <button type="button"
                                    class="btn2 btn-secondary mt-2 clear_btn"
                                    data-form="myForm">
                                <i class="fas fa-eraser"></i> @Loc.T("Common.Reset")
                            </button>
                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden"
                           id="@nameof(queryModel.OrderBy)"
                           name="@nameof(queryModel.OrderBy)"
                           value="@queryModel.OrderBy" />
                    <input type="hidden"
                           id="@nameof(queryModel.SortDir)"
                           name="@nameof(queryModel.SortDir)"
                           value="@queryModel.SortDir" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageSize)"
                           name="@nameof(queryModel.PageSize)"
                           value="@queryModel.PageSize" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageNumber)"
                           name="@nameof(queryModel.PageNumber)"
                           value="@queryModel.PageNumber" />
                </div>
            </div>
        </div>
    </div>
</form>

<div class="table">
    <table class="table table-striped table-hover table-bordered text-break" id="myTable">
        <thead>
            <tr>
                @foreach (var item in headers)
                {
                    @*不排序*@
                    <th>@Loc.T(item.Value)</th>
                }
                <th class="col-actions">@Loc.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(headers.Count + 1)">@Loc.T("Common.NoData")</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    // 判斷這列是否有上層（MenuItemParentId 不為 null / 空字串 / 0 就當作有 parent）
                    var hasParent = false;
                    if (row.TryGetValue("MenuItemParentId", out var parentCell) && parentCell != null)
                    {
                        var parentText = parentCell.ToString();
                        if (!string.IsNullOrWhiteSpace(parentText) && parentText != "0")
                        {
                            hasParent = true;
                        }
                    }

                    <tr>
                        @foreach (var key in headers.Keys)  @* 依表頭順序取值 *@
                        {
                            if (!row.TryGetValue(key, out var cell))
                            {
                                cell = "";
                            }

                            string value = TableHelper.FormatValue(cell, Loc);

                            var isRowNum = key.Equals("RowNum", StringComparison.OrdinalIgnoreCase);
                            var classes = new List<string>();

                            if (value == "(" + Loc.T("Common.None") + ")")
                            {
                                classes.Add("none-data");
                            }
                            if (isRowNum)
                            {
                                classes.Add("text-nowrap");
                            }

                            // Root（沒有 parent）的標題欄位 → 靠左顯示
                            if ((key == "MenuItemTitle" || key == "MenuItemDisplayOrder") && !hasParent)
                            {
                                classes.Add("text-start");
                                // 如果想讓 root 更明顯也可以加粗
                                classes.Add("fw-bold");
                            }

                            <td class="@string.Join(" ", classes)">

                                @if (key == "MenuItemIcon")
                                {
                                    <i class="@value"
                                       title="@value"
                                       data-bs-toggle="tooltip"
                                       data-bs-placement="top"></i>
                                }
                                else
                                {
                                    @Html.Raw(value)
                                }

                            </td>
                        }

                        <td class="col-actions">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @Loc.T("Common.Actions")
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item detail" href="@Url.Action("Details", "MenuItem", new { id = row["MenuItemId"] })">@Loc.T("Common.View")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Edit", "MenuItem", new { id = row["MenuItemId"] })">@Loc.T("Common.Edit")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Delete", "MenuItem", new { id = row["MenuItemId"] })">@Loc.T("Common.Delete")</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>

    </table>
</div>

@await Html.PartialAsync("_PagerSection", queryModel)

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">

    </script>
}
