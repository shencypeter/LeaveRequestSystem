@model BioMedDocManager.Models.MenuItem

@{
    ViewData["Title"] = Loc.T("MenuItem.Details.Title");
    Layout = "_NoNavLayout";
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-search me-2"></i>@ViewData["Title"]
    </h4>

    <div class="pop">

        <div class="row align-items-center my-2">
            <label class="col-md-2 col-form-label text-md-end">
                @Loc.T("MenuItem.Parent")
            </label>
            <div class="col-md-10">
                <p class="form-control-plaintext">
                    @if (Model.Parent != null)
                    {
                        @(Model.Parent.MenuItemTitleDisplay ?? Model.Parent.MenuItemTitle)
                    }
                    else
                    {
                        @Loc.T("Common.None")
                    }
                </p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="MenuItemTitle" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">@Model.MenuItemTitle</p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="MenuItemIcon" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                @if (!string.IsNullOrWhiteSpace(Model.MenuItemIcon))
                {
                    <div class="d-flex align-items-center gap-3">
                        <i class="@Model.MenuItemIcon"></i>
                        <span>@Model.MenuItemIcon</span>
                    </div>
                }
                else
                {
                    <p class="form-control-plaintext text-muted">@Loc.T("Common.None")</p>
                }
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="MenuItemDisplayOrder" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">@Model.MenuItemDisplayOrder</p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="MenuItemIsActive" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">
                    @(Model.MenuItemIsActive? Loc.T("Common.Enabled") : Loc.T("Common.Disabled"))
                </p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label class="col-md-2 col-form-label text-md-end">
                @Loc.T("MenuItem.ResourceKey")
            </label>
            <div class="col-md-10">
                <p class="form-control-plaintext">
                    @if (Model.Resource != null && !string.IsNullOrWhiteSpace(Model.Resource.ResourceKey))
                    {
                        <a href="@Url.Action("Index", Model.Resource.ResourceKey)" target="_blank">@Model.Resource.ResourceKey</a>
                    }
                    else
                    {
                        @Loc.T("Common.None")
                    }
                </p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="CreatedAt" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">
                    @(Model.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? Loc.T("Common.None"))
                </p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="UpdatedAt" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">
                    @(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? Loc.T("Common.None"))
                </p>
            </div>
        </div>

    </div>
</div>
