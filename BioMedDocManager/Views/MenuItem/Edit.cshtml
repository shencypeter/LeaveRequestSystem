@model BioMedDocManager.Models.MenuItem
@{
    ViewData["Title"] = Loc.T("MenuItem.Edit.Title");
    Layout = "_NoNavLayout";

    var parentList = ViewBag.ParentMenuItems as List<MenuItem> ?? new();
    var resourceList = ViewBag.Resources as List<Resource> ?? new();
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-pencil-square me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Edit"
          asp-route-menuItemId="@Model.MenuItemId"
          method="post"
          id="myForm"
          target="_top">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="MenuItemId" />

        <div class="pop">

            <!-- 上層選單 -->
            <div class="row align-items-center my-3">
                <label asp-for="MenuItemParentId" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <select asp-for="MenuItemParentId"
                            class="form-select"
                            asp-items="@(new SelectList(parentList, "MenuItemId", "MenuItemTitle"))">
                        <option value="">@Loc.T("Common.None")</option>
                    </select>
                    <span asp-validation-for="MenuItemParentId" class="text-danger"></span>
                </div>
            </div>

            <!-- 圖示 -->
            <div class="row align-items-center my-3">
                <label asp-for="MenuItemIcon" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white" id="iconPreviewWrap" title="Icon preview">
                            <i id="iconPreview"
                               class="@(string.IsNullOrWhiteSpace(Model.MenuItemIcon) ? "fa-regular fa-square" : Model.MenuItemIcon)"></i>
                        </span>
                        <input asp-for="MenuItemIcon"
                               class="form-control"
                               id="menuItemIconInput"
                               placeholder="fa-solid fa-house" />
                    </div>

                    <div class="form-text d-flex align-items-center gap-2 mt-2 d-none">
                        <span class="badge text-bg-light border" id="iconClassPreview">
                            @(string.IsNullOrWhiteSpace(Model.MenuItemIcon) ? "fa-regular fa-square" : Model.MenuItemIcon)
                        </span>
                        <span class="text-muted">即時預覽</span>
                    </div>

                    <span asp-validation-for="MenuItemIcon" class="text-danger"></span>

                    <a href="https://fontawesome.com/v6/search?ic=free-collection"
                       target="_blank"
                       title="@Loc.T("MenuItem.Icon.SearchTitle")"
                       class="d-inline-block mt-2">
                        <i class="fa-solid fa-magnifying-glass me-1"></i>
                        @Loc.T("MenuItem.Icon.SearchLink")
                    </a>
                </div>
            </div>

            <!-- 顯示順序 -->
            <div class="row align-items-center my-3">
                <label asp-for="MenuItemDisplayOrder" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <input asp-for="MenuItemDisplayOrder" class="form-control" />
                    <span asp-validation-for="MenuItemDisplayOrder" class="text-danger"></span>
                </div>
            </div>

            <!-- 是否啟用 -->
            <div class="row align-items-center my-3">
                <label asp-for="MenuItemIsActive" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <div class="form-check">
                        <input asp-for="MenuItemIsActive" class="form-check-input" />
                    </div>
                    <span asp-validation-for="MenuItemIsActive" class="text-danger"></span>
                </div>
            </div>

            <!-- ResourceKey（由 ResourceId 決定） -->
            <div class="row align-items-center my-3">
                <label asp-for="ResourceId" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <select asp-for="ResourceId"
                            class="form-select"
                            asp-items="@(new SelectList(resourceList, "ResourceId", "ResourceKey"))">
                        <option value="">@Loc.T("Common.None")</option>
                    </select>
                    <span asp-validation-for="ResourceId" class="text-danger"></span>
                </div>
            </div>

            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    <button type="submit" class="btn2 btn-success mt-2 col-6 col-md-3 mx-1">
                        <i class="fas fa-check-circle me-1"></i> @Loc.T("Common.Save")
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">
        (() => {
            const input = document.getElementById('menuItemIconInput');
            const preview = document.getElementById('iconPreview');
            const classPreview = document.getElementById('iconClassPreview');
            const fallbackClass = 'fa-solid fa-ellipsis';

            function getFontCheckString(iconClass) {
                if (iconClass.includes('fa-brands')) {
                    return '400 16px "Font Awesome 6 Brands"';
                }

                if (iconClass.includes('fa-regular')) {
                    return '400 16px "Font Awesome 6 Free"';
                }

                return '900 16px "Font Awesome 6 Free"';
            }

            function hasPseudoContent(iconClass) {
                const probe = document.createElement('i');
                probe.className = iconClass;
                probe.style.position = 'absolute';
                probe.style.left = '-9999px';
                probe.style.top = '-9999px';
                document.body.appendChild(probe);

                const before = window.getComputedStyle(probe, '::before');
                const content = before.getPropertyValue('content');

                document.body.removeChild(probe);

                return content && content !== 'none' && content !== 'normal' && content !== '""';
            }

            async function renderIcon() {
                if (!input || !preview || !classPreview) return;

                const value = (input.value || '').trim();
                const iconClass = value || fallbackClass;

                preview.className = iconClass;
                classPreview.textContent = iconClass;

                let isValid = false;

                try {
                    const hasContent = hasPseudoContent(iconClass);
                    const fontReady = document.fonts
                        ? await document.fonts.check(getFontCheckString(iconClass))
                        : true;

                    isValid = hasContent && fontReady;
                } catch {
                    isValid = false;
                }

                if (!isValid) {
                    preview.className = fallbackClass;
                    classPreview.textContent = `${iconClass}  (fallback)`;
                    classPreview.className = 'badge text-bg-warning border';
                } else {
                    classPreview.className = 'badge text-bg-light border';
                }
            }

            if (input) {
                input.addEventListener('keyup', renderIcon);
                input.addEventListener('change', renderIcon);
                input.addEventListener('paste', () => setTimeout(renderIcon, 0));
            }

            if (document.fonts && document.fonts.ready) {
                document.fonts.ready.then(renderIcon);
            }

            renderIcon();
        })();
    </script>
}