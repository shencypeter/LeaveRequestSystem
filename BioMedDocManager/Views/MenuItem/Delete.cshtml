@model BioMedDocManager.Models.MenuItem

@{
    ViewData["Title"] = "選單項目管理-刪除";
    Layout = "_NoNavLayout";

    bool hasChildren = ViewBag.HasChildren ?? false;
    int childrenCount = ViewBag.ChildrenCount ?? 0;
    var children = ViewBag.ChildrenList as List<BioMedDocManager.Models.MenuItem> ?? new();
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Delete"
          asp-route-menuItemId="@Model.MenuItemId"
          method="post"
          id="myForm"
          target="_top">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="MenuItemId" />

        <div class="pop">

            <!-- 基本資訊 -->
            <div class="row align-items-center my-2">
                <label class="col-md-2 col-form-label text-md-end">
                    上層選單
                </label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">
                        @if (Model.Parent != null)
                        {
                            @($"{Model.Parent.MenuItemTitle} (ID: {Model.MenuItemParentId})")
                        }
                        else
                        {
                            @:無
                        }
                    </p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemTitle" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.MenuItemTitle</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemIcon" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.MenuItemIcon</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemDisplayOrder" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.MenuItemDisplayOrder</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemIsActive" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">
                        @(Model.MenuItemIsActive ? "啟用" : "停用")
                    </p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="ResourceKey" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">
                        @if (Model.Resource != null)
                        {
                            @Model.Resource.ResourceKey
                        }
                        else
                        {
                            @:無
                        }
                    </p>
                </div>
            </div>

            <!-- 子選單使用狀況 + 明細 -->
            <div class="row align-items-start my-2">
                <label class="col-md-2 col-form-label text-md-end">
                    子選單狀況
                </label>
                <div class="col-md-10">
                    @if (!hasChildren)
                    {
                        <div class="text-muted">
                            目前沒有任何子選單掛在此選單之下。
                        </div>
                    }
                    else
                    {
                        <p class="text-danger mb-2">
                            此選單底下目前有 <strong>@childrenCount</strong> 個子選單：
                        </p>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>序號</th>
                                        <th>選單標題</th>
                                        <th>顯示順序</th>
                                        <th>狀態</th>
                                        <th>連結</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < children.Count; i++)
                                    {
                                        var c = children[i];
                                        <tr>
                                            <td>@(i + 1)</td>
                                            <td>@c.MenuItemTitle</td>
                                            <td>@c.MenuItemDisplayOrder</td>
                                            <td>@c.MenuItemIsActiveText</td>
                                            <td>@(c.Resource != null ? c.Resource.ResourceKey : "無")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (hasChildren)
            {
                <div class="alert alert-danger mb-0">
                    此選單目前仍有子選單，<strong>無法刪除</strong>。<br />
                    若要刪除，請先將子選單移除或重新指定其上層選單。
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    確定要刪除選單：
                    <strong>@Model.MenuItemTitle</strong> 嗎？
                </div>
            }

            <!-- 按鈕區 -->
            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    @if (!hasChildren)
                    {
                        <button type="submit" class="btn2 btn-danger mt-2 col-6 col-md-3 mx-1">
                            <i class="bi bi-trash"></i> @Loc.T("Common.Delete")
                        </button>
                    }
                </div>
            </div>

        </div>
    </form>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">

    </script>
}
