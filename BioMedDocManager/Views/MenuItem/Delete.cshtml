@model BioMedDocManager.Models.MenuItem

@{
    ViewData["Title"] = Loc.T("MenuItem.Delete.Title");
    Layout = "_NoNavLayout";

    bool hasChildren = ViewBag.HasChildren ?? false;
    int childrenCount = ViewBag.ChildrenCount ?? 0;
    var children = ViewBag.ChildrenList as List<MenuItem> ?? new();
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Delete"
          asp-route-menuItemId="@Model.MenuItemId"
          method="post"
          id="myForm"
          target="_top">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="MenuItemId" />

        <div class="pop">

            <!-- 基本資訊 -->
            <div class="row align-items-center my-2">
                <label class="col-md-2 col-form-label text-md-end">
                    @Loc.T("MenuItem.Parent")
                </label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">
                        @if (Model.Parent != null)
                        {
                            var parentTitle = Model.Parent.MenuItemTitleDisplay ?? Model.Parent.MenuItemTitle;
                            <text>@parentTitle (@Loc.T("Common.Id") @Model.MenuItemParentId)</text>
                        }
                        else
                        {
                            @Loc.T("Common.None")
                        }
                    </p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemTitle" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.MenuItemTitle</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemIcon" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.MenuItemIcon</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemDisplayOrder" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.MenuItemDisplayOrder</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="MenuItemIsActive" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">
                        @(Model.MenuItemIsActive? Loc.T("Common.Enabled") : Loc.T("Common.Disabled"))
                    </p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label class="col-md-2 col-form-label text-md-end">
                    @Loc.T("MenuItem.ResourceKey")
                </label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">
                        @(Model.Resource != null ? Model.Resource.ResourceKey : Loc.T("Common.None"))
                    </p>
                </div>
            </div>

            <!-- 子選單狀況 + 明細 -->
            <div class="row align-items-start my-2">
                <label class="col-md-2 col-form-label text-md-end">
                    @Loc.T("MenuItem.Children.Status")
                </label>
                <div class="col-md-10">
                    @if (!hasChildren)
                    {
                        <div class="text-muted">
                            @Loc.T("MenuItem.Children.EmptyHint")
                        </div>
                    }
                    else
                    {
                        <p class="text-danger mb-2">
                            @Loc.T("MenuItem.Children.Count.Prefix")
                            <strong>@childrenCount</strong>
                            @Loc.T("MenuItem.Children.Count.Suffix")
                        </p>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>@Loc.T("Common.RowNum")</th>
                                        <th>@Loc.T("MenuItem.MenuItemTitle")</th>
                                        <th>@Loc.T("MenuItem.MenuItemDisplayOrder")</th>
                                        <th>@Loc.T("Common.Status")</th>
                                        <th>@Loc.T("MenuItem.ResourceKey")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < children.Count; i++)
                                    {
                                        var c = children[i];
                                        var title = c.MenuItemTitleDisplay ?? c.MenuItemTitle;

                                        <tr>
                                            <td>@(i + 1)</td>
                                            <td>@title</td>
                                            <td>@c.MenuItemDisplayOrder</td>
                                            <td>@(c.MenuItemIsActive? Loc.T("Common.Enabled") : Loc.T("Common.Disabled"))</td>
                                            <td>@(c.Resource != null ? c.Resource.ResourceKey : Loc.T("Common.None"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (hasChildren)
            {
                <div class="alert alert-danger mb-0">
                    @Loc.T("MenuItem.Delete.BlockedLine1")<br />
                    @Loc.T("MenuItem.Delete.BlockedLine2")
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    @Loc.T("Common.ConfirmDelete")
                    <strong>@(Model.MenuItemTitleDisplay ?? Model.MenuItemTitle)</strong>
                </div>
            }

            <!-- 按鈕區 -->
            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    @if (!hasChildren)
                    {
                        <button type="submit" class="btn2 btn-danger mt-2 col-6 col-md-3 mx-1">
                            <i class="bi bi-trash"></i> @Loc.T("Common.Delete")
                        </button>
                    }
                </div>
            </div>

        </div>
    </form>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce"></script>
}
