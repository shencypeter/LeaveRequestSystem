@model WorkCalendarVm
@using System.Globalization

@{
    Layout = "_NoNavLayout"; // 套用無Nav的Layout
    ViewData["Title"] = "Work Calendar";
    var monthName = CultureInfo
        .GetCultureInfo("zh-TW")
        .DateTimeFormat
        .GetMonthName(Model.Month);
}

<style nonce="@ViewBag.CspNonce">

    .badge-outline-primary {
        color: #0d6efd;
        background-color: transparent;
        border: 1px solid #0d6efd;
    }

    .badge-outline-secondary {
        color: #6c757d;
        background-color: transparent;
        border: 1px solid #6c757d;
    }

    .badge-outline-danger {
        color: #dc3545;
        background-color: transparent;
        border: 1px solid #dc3545;
    }

    .left-meta {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
        margin-left: 8px;
    }

        .left-meta .badge {
            font-size: 0.72rem;
            font-weight: 500;
        }

    .day-row {
        border-radius: 10px;
        padding: 6px 10px;
    }

    .wknd {
        background: #e7f7ea;
    }
    /* weekend green */

    .holi {
        background: #ffe7e7;
    }
    /* holiday red */

    .meta {
        font-size: .9rem;
        opacity: .85;
    }

    .col-title {
        font-weight: 600;
        opacity: .85;
    }


    /* ===== Year calendar component ===== */
    .year-cal {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 1.5rem;
    }

    .year-cal__month {
        border: 1px solid #dee2e6;
        border-radius: 12px;
        background: #fff;
        padding: 10px;
        min-width: 0;
    }

    .year-cal__title {
        text-align: center;
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 8px;
    }

    .year-cal__weekdays,
    .year-cal__grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
    }

    .year-cal__weekdays {
        margin-bottom: 4px;
    }

    .day-row .badge + .badge {
        margin-left: 4px;
    }

    .year-cal__weekday {
        text-align: center;
        font-size: 0.72rem;
        color: #6c757d;
        padding: 2px 0;
    }

    .year-cal__day {
        position: relative;
        text-align: center;
        font-size: 0.8rem;
        line-height: 1;
        padding: 8px 2px 10px;
        min-height: 34px;
        border-radius: 8px;
    }

        .year-cal__day.is-other-month {
            color: #c0c4c8;
        }

        .year-cal__day.is-weekend {
            background: #f7fbf7;
        }

        .year-cal__day.is-today {
            outline: 2px solid #0d6efd;
            outline-offset: -2px;
            font-weight: 700;
        }

        .year-cal__day.is-holiday::after {
            content: "";
            position: absolute;
            left: 18%;
            right: 18%;
            bottom: 4px;
            height: 3px;
            border-radius: 999px;
            background: #dc3545;
        }

    .year-cal__daynum {
        display: inline-block;
    }

    @@media (max-width: 992px) {
        .year-cal {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 576px) {
        .year-cal {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container py-3">

    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div>
            <h3 class="m-0">@Model.Year 年 @monthName</h3>
            <div class="meta">工時表匯出</div>
        </div>
        @{
            var prevMonth = Model.Month > 1 ? Model.Month - 1 : 1;
            var nextMonth = Model.Month < 12 ? Model.Month + 1 : 12;

            var prevDisabled = Model.Month <= 1;
            var nextDisabled = Model.Month >= 12;
        }

        <div class="d-flex gap-2 align-items-end flex-wrap">

            <!-- Prev -->
            <form method="get" class="d-flex align-items-end">
                <input type="hidden" name="year" value="2026" />
                <input type="hidden" name="month" value="@prevMonth" />
                <button class="btn btn-outline-secondary" type="submit" @(prevDisabled ? "disabled" : "")>
                    ◀ 上個月
                </button>
            </form>

            <!-- Selector + Go -->
            <form method="get" class="d-flex gap-2 align-items-end">
                <div>
                    <div class="col-title">年度</div>
                    <select class="form-select" name="year" disabled>
                        <option value="2026" selected>2026</option>
                    </select>
                    <input type="hidden" name="year" value="2026" />
                </div>

                <div>
                    <div class="col-title">月份</div>
                    <select class="form-select" name="month">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == Model.Month)">
                                @m
                            </option>
                        }
                    </select>
                </div>

                <button class="btn btn-primary" type="submit">
                    Go
                </button>
            </form>

            <!-- Next -->
            <form method="get" class="d-flex align-items-end">
                <input type="hidden" name="year" value="2026" />
                <input type="hidden" name="month" value="@nextMonth" />
                <button class="btn btn-outline-secondary" type="submit" @(nextDisabled ? "disabled" : "")>
                    下個月 ▶
                </button>
            </form>

        </div>
    </div>


    <div class="row g-3">

        <!-- 上旬 -->
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header">上旬</div>

                <div class="card-body d-grid gap-2">
                    @foreach (var d in Model.Left)
                    {
                        var cls = d.IsWeekend ? "wknd" : (d.IsHoliday ? "holi" : "");

                        <div class="day-row @cls">
                            <div class="d-flex justify-content-between">

                                <div class="d-flex align-items-center flex-wrap">
                                    <strong>@d.Date.ToString("MM/dd")</strong>

                                    <span class="meta ms-1">
                                        (@d.Date.ToString("ddd", CultureInfo.GetCultureInfo("zh-TW")))
                                    </span>

                                    <span class="left-meta">
                                        @if (!string.IsNullOrWhiteSpace(d.LunarLabel))
                                        {
                                            <span class="badge badge-outline-secondary">
                                                @d.LunarLabel
                                            </span>
                                        }

                                        @if (d.Date.Date == DateTime.Today.Date)
                                        {
                                            <span class="badge badge-outline-primary">
                                                今日
                                            </span>
                                        }
                                    </span>
                                </div>

                                <div class="text-end">
                                    @if (d.IsWeekend)
                                    {
                                        <span class="badge bg-danger">
                                            週末
                                        </span>
                                    }
                                    else if (d.IsHoliday)
                                    {
                                        <span class="badge bg-danger">
                                            @d.HolidayName
                                        </span>
                                    }
                                    else
                                    {
                                        if (d.Date <= DateTime.Today)
                                        {
                                            <span class="badge badge-outline-secondary">
                                                出勤 08:00-12:00
                                            </span>
                                        }

                                        <span class="badge badge-outline-danger">
                                            特休 13:00-17:00
                                        </span>
                                    }

                                </div>

                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>

        <!-- 下旬 -->
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header">下旬</div>

                <div class="card-body d-grid gap-2">
                    @foreach (var d in Model.Right)
                    {
                        var cls = d.IsWeekend ? "wknd" : (d.IsHoliday ? "holi" : "");

                        <div class="day-row @cls">
                            <div class="d-flex justify-content-between">

                                <div class="d-flex align-items-center flex-wrap">
                                    <strong>@d.Date.ToString("MM/dd")</strong>

                                    <span class="meta ms-1">
                                        (@d.Date.ToString("ddd", CultureInfo.GetCultureInfo("zh-TW")))
                                    </span>

                                    <span class="left-meta">
                                        @if (!string.IsNullOrWhiteSpace(d.LunarLabel))
                                        {
                                            <span class="badge badge-outline-secondary">
                                                @d.LunarLabel
                                            </span>
                                        }

                                        @if (d.Date.Date == DateTime.Today.Date)
                                        {
                                            <span class="badge badge-outline-primary">
                                                今日
                                            </span>
                                        }
                                    </span>
                                </div>

                                <div class="text-end">
                                    @if (d.IsWeekend)
                                    {
                                        <span class="badge bg-danger">
                                            週末
                                        </span>
                                    }
                                    else if (d.IsHoliday)
                                    {
                                        <span class="badge bg-danger">
                                            @d.HolidayName
                                        </span>
                                    }
                                    else
                                    {
                                        if (d.Date <= DateTime.Today)
                                        {
                                            <span class="badge badge-outline-secondary">
                                                出勤 08:00-12:00
                                            </span>
                                        }

                                        <span class="badge badge-outline-danger">
                                            特休 13:00-17:00
                                        </span>
                                    }

                                </div>

                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>

    </div>
    <div id="cal"></div>
    <div class="mt-3 p-3 rounded border bg-light">
        <div>
            <strong>本月工作日：</strong>
            @Model.WorkingDays 天
        </div>
        <div>
            <strong>本月工時：</strong>
            @Model.WorkingHours 小時（8 小時/日）
        </div>
    </div>


</div>


<script nonce="@ViewBag.CspNonce">
    document.addEventListener("DOMContentLoaded", function () {

        const holidayMap = {
            "2026-01-01": "中華民國開國紀念日",

            "2026-02-15": "小年夜",
            "2026-02-16": "農曆除夕",
            "2026-02-17": "春節",
            "2026-02-18": "春節",
            "2026-02-19": "春節",
            "2026-02-20": "補假",

            "2026-02-27": "補假",
            "2026-02-28": "和平紀念日",

            "2026-04-03": "補假",
            "2026-04-04": "兒童節",
            "2026-04-05": "清明節",
            "2026-04-06": "補假",

            "2026-05-01": "勞動節",

            "2026-06-19": "端午節",

            "2026-09-25": "中秋節",
            "2026-09-28": "教師節",

            "2026-10-09": "補假",
            "2026-10-10": "國慶日",
            "2026-10-25": "臺灣光復暨金門古寧頭大捷紀念日",
            "2026-10-26": "補假",

            "2026-12-25": "行憲紀念日"
        };

        class YearCalendar {
            constructor(container, options) {
                this.container = container;
                this.year = options.year;
                this.month = options.month; // 1-12
                this.holidayMap = options.holidayMap || {};
                this.weekdayLabels = options.weekdayLabels || ["一", "二", "三", "四", "五", "六", "日"];
            }

            render() {
                this.container.innerHTML = "";
                this.container.className = "year-cal";

                const monthsToShow = [
                    this.resolveMonth(this.year, this.month - 1),
                    this.resolveMonth(this.year, this.month),
                    this.resolveMonth(this.year, this.month + 1)
                ];

                monthsToShow.forEach(({ year, month }) => {
                    this.container.appendChild(this.renderMonth(year, month));
                });
            }

            resolveMonth(year, month) {
                const d = new Date(year, month - 1, 1);
                return {
                    year: d.getFullYear(),
                    month: d.getMonth() + 1
                };
            }

            renderMonth(year, month) {
                const card = document.createElement("div");
                card.className = "year-cal__month";

                const title = document.createElement("div");
                title.className = "year-cal__title";
                title.textContent = `${year} 年 ${month} 月`;
                card.appendChild(title);

                const weekdays = document.createElement("div");
                weekdays.className = "year-cal__weekdays";

                this.weekdayLabels.forEach(label => {
                    const el = document.createElement("div");
                    el.className = "year-cal__weekday";
                    el.textContent = label;
                    weekdays.appendChild(el);
                });

                card.appendChild(weekdays);

                const grid = document.createElement("div");
                grid.className = "year-cal__grid";

                const firstOfMonth = new Date(year, month - 1, 1);
                const mondayFirstOffset = (firstOfMonth.getDay() + 6) % 7;
                const gridStart = new Date(year, month - 1, 1 - mondayFirstOffset);

                for (let i = 0; i < 42; i++) {
                    const date = new Date(gridStart);
                    date.setDate(gridStart.getDate() + i);

                    grid.appendChild(this.renderDay(date, year, month));
                }

                card.appendChild(grid);
                return card;
            }

            renderDay(date, currentYear, currentMonth) {
                const cell = document.createElement("div");
                cell.className = "year-cal__day";

                const ymd = this.formatDate(date);
                const isOtherMonth =
                    date.getFullYear() !== currentYear ||
                    (date.getMonth() + 1) !== currentMonth;

                const isWeekend = date.getDay() === 0 || date.getDay() === 6;
                const isHoliday = !!this.holidayMap[ymd];
                const isToday = this.isSameDate(date, new Date());

                if (isOtherMonth) {
                    cell.classList.add("is-empty");
                    cell.innerHTML = "&nbsp;";
                    return cell;
                }

                if (isWeekend) cell.classList.add("is-weekend");
                if (isHoliday) cell.classList.add("is-holiday");
                if (isToday) cell.classList.add("is-today");

                if (isHoliday) {
                    cell.title = this.holidayMap[ymd];
                }

                const num = document.createElement("span");
                num.className = "year-cal__daynum";
                num.textContent = date.getDate();

                cell.appendChild(num);
                return cell;
            }

            formatDate(date) {
                const y = date.getFullYear();
                const m = String(date.getMonth() + 1).padStart(2, "0");
                const d = String(date.getDate()).padStart(2, "0");
                return `${y}-${m}-${d}`;
            }

            isSameDate(a, b) {
                return a.getFullYear() === b.getFullYear()
                    && a.getMonth() === b.getMonth()
                    && a.getDate() === b.getDate();
            }
        }

        const cal = new YearCalendar(document.getElementById("cal"), {
            year: @Model.Year,
            month: @Model.Month,
            holidayMap: holidayMap,
            weekdayLabels: ["一", "二", "三", "四", "五", "六", "日"]
        });

        cal.render();
    });
</script>
}