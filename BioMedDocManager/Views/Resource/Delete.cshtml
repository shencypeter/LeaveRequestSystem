@model BioMedDocManager.Models.Resource
@using BioMedDocManager.Models

@{
    ViewData["Title"] = "系統資源管理-刪除";
    Layout = "_NoNavLayout";

    var groupUsage = ViewBag.ResourceGroupUsageList as List<ResourceGroupUsageViewModel> ?? new();
    int groupCount = groupUsage.Count;

    bool hasAnyRolePermission = ViewBag.HasAnyRolePermission ?? false;
    int rolePermCount = ViewBag.RolePermissionCount ?? 0;
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Delete"
          asp-route-resourceId="@Model.ResourceId"
          method="post"
          id="myForm"
          target="_top">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ResourceId" />

        <div class="pop">

            <!-- 基本資訊 -->
            <div class="row align-items-center my-2">
                <label asp-for="ResourceType" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ResourceType</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="ResourceKey" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ResourceKey</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="ResourceDisplayName" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.ResourceDisplayName</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="ResourceIsActive" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">
                        @Model.ResourceIsActiveText
                    </p>
                </div>
            </div>

            <!-- 角色權限使用狀況 + 使用者群組／未指定群組 -->
            <div class="row align-items-start my-2">
                <label class="col-md-2 col-form-label text-md-end">
                    角色權限使用狀況
                </label>
                <div class="col-md-10">

                    @if (!hasAnyRolePermission)
                    {
                        <div class="text-muted">
                            目前尚未有任何角色權限使用此資源。
                        </div>
                    }
                    else
                    {
                        <p class="mb-2">
                            此資源目前被 <strong>@rolePermCount</strong> 個角色設定權限。
                        </p>

                        @if (groupCount > 0)
                        {

                            // 依 Role 分組，每個角色一行，群組名稱用「、」串起來
                            var roleGroups = groupUsage
                            .GroupBy(g => new { g.RoleId, g.RoleGroup, g.RoleName })
                            .OrderBy(g => g.Key.RoleGroup)
                            .ThenBy(g => g.Key.RoleName);


                            <div class="mb-2">
                                <h6>使用此資源的角色／群組：</h6>
                                <ol class="mb-0">
                                    @foreach (var roleGroup in roleGroups)
                                    {
                                        var key = roleGroup.Key;

                                        // 有群組的項目
                                        var groupsForRole = roleGroup
                                        .Where(x => x.HasGroup && !string.IsNullOrWhiteSpace(x.UserGroupName))
                                        .ToList();

                                        if (!groupsForRole.Any())
                                        {
                                            // 完全沒有指定群組
                                            <li>
                                                【@key.RoleGroup】@key.RoleName ：
                                                <span class="text-muted">未指定群組</span>
                                            </li>
                                        }
                                        else
                                        {
                                            // 把所有群組名稱用「、」串起來
                                            var names = string.Join("、", groupsForRole.Select(x => x.UserGroupName));

                                            <li>
                                                【@key.RoleGroup】@key.RoleName ：@names
                                            </li>
                                        }
                                    }
                                </ol>
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">
                                目前已由部分角色設定權限，但尚未指定任何使用者群組。
                            </div>
                        }
                    }
                </div>
            </div>

            @if (hasAnyRolePermission)
            {
                <div class="alert alert-danger mb-0">
                    此資源目前仍被角色權限使用，<strong>無法刪除</strong>。<br />
                    若要刪除，請先在「角色管理-權限設定」中取消此資源相關的權限設定。
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    確定要刪除資源：
                    <strong>@Model.ResourceKey (@Model.ResourceDisplayName)</strong> 嗎？
                </div>
            }

            <!-- 按鈕區 -->
            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    @if (!hasAnyRolePermission)
                    {
                        <button type="submit" class="btn2 btn-danger mt-2 col-6 col-md-3 mx-1">
                            <i class="bi bi-trash"></i>&ensp;確定刪除
                        </button>
                    }
                </div>
            </div>

        </div>
    </form>
</div>
