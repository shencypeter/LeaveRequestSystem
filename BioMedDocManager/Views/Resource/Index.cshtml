@using BioMedDocManager.Extensions
@using BioMedDocManager.Models
@model IEnumerable<Dictionary<string, object>>

@{
    ViewData["Title"] = Loc.T("Resource.Index.Title");
    Layout = "_AssetLayout";

    var queryModel = QueryableExtensions.GetSessionQueryModel<ResourceQueryViewModel>(Context);
    queryModel.OrderBy ??= "ResourceKey";
    queryModel.SortDir ??= "asc";

    var headers = ViewData["tableHeaders"] as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<form method="post" id="myForm">
    @Html.AntiForgeryToken()

    <div class="accordion" id="queryAccordion">
        <!-- 資源查詢設定 -->
        <div class="accordion-item border border-secondary-subtle bg-light">
            <h2 class="accordion-header" id="resourceHeading">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#resourceCollapse" aria-expanded="false" aria-controls="resourceCollapse">
                    <i class="fa fa-database me-2"></i> @ViewData["Title"]
                </button>
            </h2>
            <div id="resourceCollapse" class="accordion-collapse collapse show" aria-labelledby="resourceHeading"
                 data-bs-parent="#queryAccordion">
                <div class="accordion-body mx-3">

                    <!-- Row 1: 資源類型 / 資源代碼 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">

                        <!-- 組1：資源類型 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="ResourceType" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("Resource.ResourceType")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="ResourceType"
                                           name="@nameof(ResourceQueryViewModel.ResourceType)"
                                           value="@queryModel.ResourceType"
                                           placeholder="@Loc.T("Resource.ResourceKey.Placeholder")" />
                                </div>
                            </div>
                        </div>

                        <!-- 組2：資源代碼 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="ResourceKey" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("Resource.ResourceKey")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="ResourceKey"
                                           name="@nameof(ResourceQueryViewModel.ResourceKey)"
                                           value="@queryModel.ResourceKey"
                                           placeholder="@Loc.T("Resource.ResourceKey.Placeholder")" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2:是否啟用 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">
                        <!-- 組1：是否啟用 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="ResourceIsActive" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    @Loc.T("Resource.ResourceIsActive")：
                                </label>
                                <div class="col-12 col-sm-8">
                                    @await Html.PartialAsync("_BoolNullableSelect", new BoolNullableSelectVm
                                    {
                                        Id = "ResourceIsActive",
                                        Name = nameof(ResourceQueryViewModel.ResourceIsActive),
                                        Value = queryModel.ResourceIsActive
                                    })
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 按鈕排 -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center flex-wrap gap-2">

                            <button type="submit" class="btn2 btn-primary mt-2 search_btn">
                                <i class="fas fa-search"></i> @Loc.T("Common.Search")
                            </button>

                            <a id="create_btn" href="@Url.Action("Create", "Resource")"
                               class="btn2 btn-success mt-2">
                                <i class="fas fa-plus-circle"></i> @Loc.T("Common.Create")
                            </a>

                            <button type="button" class="btn2 btn-secondary mt-2 clear_btn" data-form="myForm">
                                <i class="fas fa-eraser"></i> @Loc.T("Common.Reset")
                            </button>
                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden"
                           id="@nameof(queryModel.OrderBy)"
                           name="@nameof(queryModel.OrderBy)"
                           value="@queryModel.OrderBy" />
                    <input type="hidden"
                           id="@nameof(queryModel.SortDir)"
                           name="@nameof(queryModel.SortDir)"
                           value="@queryModel.SortDir" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageSize)"
                           name="@nameof(queryModel.PageSize)"
                           value="@queryModel.PageSize" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageNumber)"
                           name="@nameof(queryModel.PageNumber)"
                           value="@queryModel.PageNumber" />
                </div>
            </div>
        </div>
    </div>
</form>

<div class="table">
    <table class="table table-striped table-hover table-bordered text-break" id="myTable">
        <thead>
            <tr>
                @foreach (var item in headers)
                {
                    <th data-id="@item.Key">
                        @if (item.Key != "RowNum")
                        {
                            <a href="#" title="@($"{Loc.T("Common.SortByColumn.TooltipPrefix")}{Loc.T(item.Value)}{Loc.T("Common.SortByColumn.TooltipSuffix")}")"> @Loc.T(@item.Value)</a>
                        }
                        else
                        {
                            @Loc.T(item.Value)
                        }
                    <span class="order-index">
                        @(queryModel.OrderBy?.EndsWith(item.Key) == true
                                                ? (queryModel.SortDir == "asc" ? "▲" : "▼")
                                                : "")
                    </span>
                </th>
                                }
                <th class="col-actions">@Loc.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(headers.Count + 1)">@Loc.T("Common.NoData")</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    <tr>
                        @foreach (var key in headers.Keys)  @* 依表頭順序取值 *@
                        {
                            if (!row.TryGetValue(key, out var cell)) { cell = ""; }

                            string value = TableHelper.FormatValue(cell, Loc);

                            <td class="@(value == "(" + Loc.T("Common.None") + ")" ? "none-data" : "") @((key.Equals("RowNum", StringComparison.OrdinalIgnoreCase)) ? "text-nowrap" : "")">
                                @Html.Raw(value)
                            </td>
                        }

                        <td class="col-actions">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @Loc.T("Common.Actions")
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item detail" href="@Url.Action("Details", "Resource", new { id = row["ResourceId"] })">@Loc.T("Common.View")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Edit", "Resource", new { id = row["ResourceId"] })">@Loc.T("Common.Edit")</a></li>
                                    <li><a class="dropdown-item detail" href="@Url.Action("Delete", "Resource", new { id = row["ResourceId"] })">@Loc.T("Common.Delete")</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_PagerSection", queryModel)

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">

    </script>
}
