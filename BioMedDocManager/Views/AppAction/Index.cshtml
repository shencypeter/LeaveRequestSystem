@using BioMedDocManager.Extensions
@using BioMedDocManager.Models
@model IEnumerable<Dictionary<string, object>>

@{
    ViewData["Title"] = "系統動作管理";
    Layout = "_AssetLayout";

    var queryModel = QueryableExtensions.GetSessionQueryModel<AppActionQueryViewModel>(Context);
    queryModel.OrderBy ??= "AppActionOrder";
    queryModel.SortDir ??= "asc";

    var headers = ViewData["tableHeaders"] as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<form method="post" id="myForm">
    @Html.AntiForgeryToken()

    <div class="accordion" id="queryAccordion">
        <!-- 動作查詢設定 -->
        <div class="accordion-item border border-secondary-subtle bg-light">
            <h2 class="accordion-header" id="appActionHeading">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#appActionCollapse" aria-expanded="false" aria-controls="appActionCollapse">
                    <i class="fa fa-bolt me-2"></i> 系統動作管理
                </button>
            </h2>
            <div id="appActionCollapse" class="accordion-collapse collapse show" aria-labelledby="appActionHeading"
                 data-bs-parent="#queryAccordion">
                <div class="accordion-body mx-3">

                    <!-- Row 1: 動作名稱 / 顯示名稱 -->
                    <div class="row mb-3 g-3 row-cols-1 row-cols-md-2 align-items-center">

                        <!-- 組1：動作名稱 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="AppActionName" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    動作名稱：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="AppActionName"
                                           name="@nameof(AppActionQueryViewModel.AppActionName)"
                                           value="@queryModel.AppActionName"
                                           placeholder="例如：Index / Create / Edit / Delete" />
                                </div>
                            </div>
                        </div>

                        <!-- 組2：顯示名稱 -->
                        <div class="col">
                            <div class="row g-2 align-items-center">
                                <label for="AppActionDisplayName" class="col-12 col-sm-4 col-form-label text-sm-end text-start">
                                    顯示名稱：
                                </label>
                                <div class="col-12 col-sm-8">
                                    <input type="text"
                                           class="form-control"
                                           id="AppActionDisplayName"
                                           name="@nameof(AppActionQueryViewModel.AppActionDisplayName)"
                                           value="@queryModel.AppActionDisplayName"
                                           placeholder="請輸入顯示名稱" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 按鈕排 -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center flex-wrap gap-2">

                            <button type="submit" class="btn2 btn-primary mt-2 search_btn">
                                <i class="fas fa-search"></i>&ensp;查詢
                            </button>

                            <a id="create_btn" href="@Url.Action("Create", "AppAction")"
                               class="btn2 btn-success mt-2">
                                <i class="fas fa-plus-circle"></i>&ensp;新增動作
                            </a>

                            <button type="button" class="btn2 btn-secondary mt-2 clear_btn" data-form="myForm">
                                <i class="fas fa-eraser"></i> 清除
                            </button>
                        </div>
                    </div>

                    <!-- Hidden fields -->
                    <input type="hidden"
                           id="@nameof(queryModel.OrderBy)"
                           name="@nameof(queryModel.OrderBy)"
                           value="@queryModel.OrderBy" />
                    <input type="hidden"
                           id="@nameof(queryModel.SortDir)"
                           name="@nameof(queryModel.SortDir)"
                           value="@queryModel.SortDir" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageSize)"
                           name="@nameof(queryModel.PageSize)"
                           value="@queryModel.PageSize" />
                    <input type="hidden"
                           id="@nameof(queryModel.PageNumber)"
                           name="@nameof(queryModel.PageNumber)"
                           value="@queryModel.PageNumber" />
                </div>
            </div>
        </div>
    </div>
</form>

<div class="table">
    <table class="table table-striped table-hover table-bordered text-break" id="myTable">
        <thead>
            <tr>
                @foreach (var item in headers)
                {
                    <th data-id="@item.Key">
                        @if (item.Key != "RowNum")
                        {
                            <a href="#" title="點選「@(item.Value)」欄位進行排序"> @item.Value </a>
                        }
                        else
                        {
                            @item.Value
                        }
                    <span class="order-index">
                        @(queryModel.OrderBy?.EndsWith(item.Key) == true
                                                ? (queryModel.SortDir == "asc" ? "▲" : "▼")
                                                : "")
                    </span>
                </th>
                                }
                <th class="col-actions">功能</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(headers.Count + 1)">查無資料</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    <tr>
                        @foreach (var key in headers.Keys)  @* 依表頭順序取值 *@
                        {
                            if (!row.TryGetValue(key, out var cell))
                            {
                                cell = "";
                            }

                            string value = TableHelper.FormatValue(cell);

                            <td class="@(value == "(無)" ? "none-data" : "") @((key.Equals("RowNum", StringComparison.OrdinalIgnoreCase)) ? "text-nowrap" : "")">
                                @Html.Raw(value)
                            </td>
                        }

                        <td class="col-actions">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    功能
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item detail"
                                           href="@Url.Action("Details", "AppAction", new { id = row["AppActionId"] })">檢視</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item detail"
                                           href="@Url.Action("Edit", "AppAction", new { id = row["AppActionId"] })">編輯</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item detail"
                                           href="@Url.Action("Delete", "AppAction", new { id = row["AppActionId"] })">刪除</a>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_PagerSection", queryModel)

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">

    </script>
}
