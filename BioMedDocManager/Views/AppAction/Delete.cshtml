@model BioMedDocManager.Models.AppAction
@using BioMedDocManager.Models

@{
    ViewData["Title"] = Loc.T("AppAction.Delete.Title");
    Layout = "_NoNavLayout";

    var usageList = ViewBag.ActionRoleUsageList as List<AppActionRoleUsageViewModel> ?? new();
    bool hasAnyRolePermission = ViewBag.HasAnyRolePermission ?? false;
    int pairCount = ViewBag.RolePermissionPairCount ?? 0;
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Delete"
          asp-route-appActionId="@Model.AppActionId"
          method="post"
          id="myForm"
          target="_top">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="AppActionId" />

        <div class="pop">

            <!-- 基本資訊 -->
            <div class="row align-items-center my-2">
                <label asp-for="AppActionName" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.AppActionName</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="AppActionDisplayName" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.AppActionDisplayName</p>
                </div>
            </div>

            <div class="row align-items-center my-2">
                <label asp-for="AppActionOrder" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <p class="form-control-plaintext">@Model.AppActionOrder</p>
                </div>
            </div>

            <!-- RolePermission 關聯狀況 -->
            <div class="row align-items-start my-2">
                <label class="col-md-2 col-form-label text-md-end">
                    @Loc.T("AppAction.RolePermissionUsage.Title")
                </label>
                <div class="col-md-10">

                    @if (!hasAnyRolePermission)
                    {
                        <div class="text-muted mb-2">
                            @Loc.T("AppAction.RolePermissionUsage.None")
                        </div>

                        <div class="alert alert-warning mb-0">
                            @Loc.T("Common.ConfirmDelete")
                            <strong>@Model.AppActionName (@Model.AppActionDisplayName)</strong>
                        </div>
                    }
                    else
                    {
                        <p class="mb-2">
                            @Loc.T("AppAction.RolePermissionUsage.CountPrefix")
                            <strong>@pairCount</strong>
                            @Loc.T("AppAction.RolePermissionUsage.CountSuffix")
                            <strong>@Loc.T("AppAction.Delete.Blocked.CannotDelete")</strong>。
                        </p>

                        @if (usageList.Any())
                        {
                            <div class="table-responsive mb-2">
                                <table class="table table-sm table-bordered align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>@Loc.T("Role.RoleGroup")</th>
                                            <th>@Loc.T("Role.RoleName")</th>
                                            <th>@Loc.T("Resource.ResourceKey")</th>
                                            <th>@Loc.T("Resource.ResourceDisplayName")</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in usageList)
                                        {
                                            <tr>
                                                <td>@item.RoleGroup</td>
                                                <td>@item.RoleName</td>
                                                <td>@item.ResourceKey</td>
                                                <td>@item.ResourceDisplayName</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <div class="alert alert-danger mb-0">
                            @Loc.T("AppAction.Delete.Blocked.Instruction")
                        </div>
                    }
                </div>
            </div>

            <!-- 按鈕區 -->
            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    @if (!hasAnyRolePermission)
                    {
                        <button type="submit" class="btn2 btn-danger mt-2 col-6 col-md-3 mx-1">
                            <i class="bi bi-trash"></i> @Loc.T("Common.Delete")
                        </button>
                    }
                </div>
            </div>

        </div>
    </form>
</div>
