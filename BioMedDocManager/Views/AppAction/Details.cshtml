@model BioMedDocManager.Models.AppAction
@using BioMedDocManager.Models

@{
    ViewData["Title"] = Loc.T("AppAction.Details.Title");
    Layout = "_NoNavLayout";

    var usageList = ViewBag.ActionRoleUsageList as List<AppActionRoleUsageViewModel> ?? new();
    bool hasAnyRolePermission = ViewBag.HasAnyRolePermission ?? false;
    int pairCount = ViewBag.RolePermissionPairCount ?? 0;
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-search me-2"></i>@ViewData["Title"]
    </h4>

    <div class="pop">

        <!-- 基本資訊 -->
        <div class="row align-items-center my-2">
            <label asp-for="AppActionCode" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">@Model.AppActionCode</p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="AppActionDisplayName" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">@Model.AppActionDisplayName</p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="AppActionOrder" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">@Model.AppActionOrder</p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="CreatedAt" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">
                    @(Model.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? Loc.T("Common.None"))
                </p>
            </div>
        </div>

        <div class="row align-items-center my-2">
            <label asp-for="UpdatedAt" class="col-md-2 col-form-label text-md-end"></label>
            <div class="col-md-10">
                <p class="form-control-plaintext">
                    @(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? Loc.T("Common.None"))
                </p>
            </div>
        </div>

        <!-- RolePermission 關聯狀況 -->
        <div class="row align-items-start my-2">
            <label class="col-md-2 col-form-label text-md-end">
                @Loc.T("AppAction.RolePermissionUsage.Title")
            </label>
            <div class="col-md-10">
                @if (!hasAnyRolePermission)
                {
                    <div class="text-muted">
                        @Loc.T("AppAction.RolePermissionUsage.None")
                    </div>
                }
                else
                {
                    <p class="mb-2">
                        @Loc.T("AppAction.RolePermissionUsage.CountPrefix")
                        <strong>@pairCount</strong>
                        @Loc.T("AppAction.RolePermissionUsage.CountSuffix")
                    </p>

                    @if (usageList.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>@Loc.T("Role.RoleGroup")</th>
                                        <th>@Loc.T("Role.RoleCode")</th>
                                        <th>@Loc.T("Resource.ResourceKey")</th>
                                        <th>@Loc.T("Resource.ResourceDisplayName")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in usageList)
                                    {
                                        <tr>
                                            <td>@item.RoleGroup</td>
                                            <td>@item.RoleCode</td>
                                            <td>@item.ResourceKey</td>
                                            <td>@item.ResourceDisplayName</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">
                            @Loc.T("AppAction.RolePermissionUsage.NoDetail")
                        </div>
                    }
                }
            </div>
        </div>

    </div>
</div>
