@model BioMedDocManager.Models.AppAction
@{
    ViewData["Title"] = Loc.T("AppAction.Create.Title");
    Layout = "_NoNavLayout";
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-plus-square me-2"></i>@ViewData["Title"]
    </h4>

    <form asp-action="Create" method="post" id="myForm" target="_top">
        @Html.AntiForgeryToken()

        <div class="pop">

            <div class="row align-items-center my-3">
                <label asp-for="AppActionName" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <input asp-for="AppActionName" class="form-control" placeholder="Index / Create / Edit / Delete ..." />
                    <span asp-validation-for="AppActionName" class="text-danger"></span>
                </div>
            </div>

            <div class="row align-items-center my-3">
                <label asp-for="AppActionDisplayName" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <input asp-for="AppActionDisplayName" class="form-control" />
                    <span asp-validation-for="AppActionDisplayName" class="text-danger"></span>
                </div>
            </div>

            <div class="row align-items-center my-3">
                <label asp-for="AppActionOrder" class="col-md-2 col-form-label text-md-end"></label>
                <div class="col-md-10">
                    <input asp-for="AppActionOrder" class="form-control" type="number" />
                    <span asp-validation-for="AppActionOrder" class="text-danger"></span>
                </div>
            </div>

            <div class="row align-items-center my-3">
                <div class="col-12 d-flex flex-wrap justify-content-center">
                    <button type="submit" class="btn2 btn-success mt-2 col-6 col-md-3 mx-1">
                        <i class="fas fa-check-circle"></i> @Loc.T("Common.Save")
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">
    </script>
}
