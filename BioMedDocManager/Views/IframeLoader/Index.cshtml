@{
    Layout = "_AssetLayout";

    var frameSrc = TempData["src"] as string;
    var request = Context.Request;
    var hostPrefix = $"{request.Scheme}://{request.Host}";

    // Ensure src is a relative path before prefixing
    var absoluteFrameSrc = string.IsNullOrWhiteSpace(frameSrc)
        ? ""
        : (frameSrc.StartsWith("http") ? frameSrc : $"{hostPrefix}{frameSrc}");
}

<div class="container-fluid vh-100 p-0">
    <iframe id="iframeLoader"
            src="@absoluteFrameSrc"
            class="w-100 h-100 border-0 d-block bg-white"
            style="opacity:0; transition:opacity .2s ease;"
            nonce="@ViewBag.CspNonce"
            onload="this.style.opacity=1"
            allowfullscreen
            loading="lazy">
    </iframe>
</div>