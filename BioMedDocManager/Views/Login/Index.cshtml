@{
    ViewData["FullTitle"] = Loc.T("Common.SystemName") + "-" + Loc.T("Common.Login");
    Layout = "_LoginLayout";

    var message = TempData["_JSShowAlert"] as string;

    // 示範登入（DEBUG）
    var sampleUser = "";
    var samplePassword = "";

#if DEBUG
    sampleUser = "534159";
    samplePassword = "Abcd534159";
#endif

    // 最近登入帳號
    var lastUser = TempData["lastUserId"] as string;
    if (!string.IsNullOrEmpty(lastUser))
    {
        sampleUser = lastUser;
        samplePassword = "";
    }

    var returnUrl = ViewBag.ReturnUrl as string;
    if (!string.IsNullOrEmpty(returnUrl) && returnUrl.Contains("Login"))
    {
        returnUrl = null; // 防止導回自己
    }

    bool captchaRequired = false;
#if RELEASE
    captchaRequired = true;
#endif

    // 跑馬燈訊息
    var textareaMessage = TempData["Messages"] as string ?? "";
    var scrollMessages = textareaMessage
        .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries)
        .Select(m => m.Trim())
        .ToList();
}

<div class="Main flex-container" id="Main">
    <div class="pt-5" id="Main_Page">

        @if (scrollMessages.Any())
        {
            <marquee id="newsMarquee"
                     behavior="scroll"
                     direction="left"
                     scrollamount="7">
                @foreach (var scrollMessage in scrollMessages)
                {
                    <i class="fa-solid fa-bullhorn text-danger me-1"></i>
                    @scrollMessage @Html.Raw("&ensp;&ensp;&ensp;")
                }
            </marquee>
        }

        <div class="sub-div"></div>

        <div class="login-div">
            <div class="login-text">

                <form method="post" action="@Url.Action("Login")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="fs-3 fw-bold my-2">
                        @Loc.T("Home.Welcome.SubTitle")
                    </div>

                    @if (!string.IsNullOrEmpty(ViewBag.ReturnUrl as string))
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            @Loc.T("Login.SessionExpired")
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(message))
                    {
                        if (message.Contains("謝謝"))
                        {
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle me-2"></i>@message
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-triangle me-2"></i>@message
                            </div>
                        }
                    }

                    <!-- 帳號 -->
                    <div class="row my-3">
                        <label class="col-md-2 col-sm-3 col-12 col-form-label fw-bold">
                            @Loc.T("Login.Account")
                        </label>
                        <div class="col-md-9 col-sm-8 col-12">
                            <input type="text"
                                   class="form-control"
                                   name="userAccount"
                                   value="@sampleUser"
                                   placeholder="@Loc.T("Login.Account.Placeholder")"
                                   required />
                        </div>
                    </div>

                    <!-- 密碼 -->
                    <div class="row my-3">
                        <label class="col-md-2 col-sm-3 col-12 col-form-label fw-bold">
                            @Loc.T("Login.Password")
                        </label>
                        <div class="col-md-9 col-sm-8 col-12">
                            <div class="input-group">
                                <input type="password"
                                       class="form-control"
                                       id="password"
                                       name="password"
                                       value="@samplePassword"
                                       placeholder="@Loc.T("Login.Password.Placeholder")"
                                       required />
                                <button type="button"
                                        class="btn btn-outline-secondary togglePasswordButton"
                                        data-id="password">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- 驗證碼 -->
                    @if (captchaRequired)
                    {
                        <div class="row my-3">
                            <label class="col-md-2 col-sm-3 col-12 col-form-label fw-bold">
                                @Loc.T("Login.Captcha")
                            </label>
                            <div class="col-md-9 col-sm-8 col-12">
                                <div class="input-group">
                                    <input type="text"
                                           class="form-control text-uppercase"
                                           name="captcha"
                                           maxlength="5"
                                           pattern="[A-Za-z0-9]*"
                                           placeholder="@Loc.T("Login.Captcha.Placeholder")"
                                           required />
                                    <img id="captchaImage"
                                         src="@Url.Action("GetCaptcha", "Login")"
                                         data-url="@Url.Action("GetCaptcha", "Login")"
                                         class="captcha-img ms-2 border rounded"
                                         title="@Loc.T("Login.Captcha.RefreshTitle")"
                                         alt="@Loc.T("Login.Captcha")" />
                                </div>
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary my-3 col-sm-6">
                        @Loc.T("Common.Login")
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">
        $(function () {

            // iframe 中顯示 → 強制跳出
            if (window.top !== window.self) {

                var urlParams = new URLSearchParams(window.location.search);
                var returnUrl = urlParams.get('returnUrl');

                var redirectUrl = returnUrl
                    ? window.location.pathname + '?returnUrl=' + encodeURIComponent(returnUrl)
                    : window.location.pathname + window.location.search;

                window.top.location = redirectUrl;
            }

            // 密碼顯示切換
            passwordVisibilityListener();

            // 驗證碼刷新
            $(document).on("click error", "#captchaImage", function () {
                refreshCaptcha(this);
            });

            // 跑馬燈 hover 停止
            $(document).on("mouseover", "#newsMarquee", function () {
                this.stop();
            });
            $(document).on("mouseout", "#newsMarquee", function () {
                this.start();
            });
        });
    </script>
}
