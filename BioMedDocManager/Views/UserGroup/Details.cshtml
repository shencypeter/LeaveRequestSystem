@model BioMedDocManager.Models.UserGroup
@{
    ViewData["Title"] = Loc.T("UserGroup.Details.Title");
    Layout = "_NoNavLayout";
}

<div class="m-4">
    <h4 class="m-3 px-2">
        <i class="bi bi-search me-2"></i>@ViewData["Title"]
    </h4>

    <div class="pop">

        <!-- 基本資料 -->
        <div class="row align-items-center my-3">
            <div class="col-md-2 col-form-label text-md-end text-start">
                <strong>@Html.DisplayNameFor(m => m.UserGroupCode)：</strong>
            </div>
            <div class="col-md-10 pt-1">
                @Model.UserGroupCode
            </div>
        </div>

        <div class="row align-items-center my-3">
            <div class="col-md-2 col-form-label text-md-end text-start">
                <strong>@Html.DisplayNameFor(m => m.UserGroupDescription)：</strong>
            </div>
            <div class="col-md-10 pt-1">
                @if (string.IsNullOrWhiteSpace(Model.UserGroupDescription))
                {
                    <span class="text-muted">(無)</span>
                }
                else
                {
                    @Model.UserGroupDescription
                }
            </div>
        </div>

        <div class="row align-items-center my-3">
            <div class="col-md-2 col-form-label text-md-end text-start">
                <strong>@Html.DisplayNameFor(m => m.CreatedAt)：</strong>
            </div>
            <div class="col-md-4 pt-1">
                @{
                    var createdText = Model.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "(無)";
                }
                @createdText
            </div>

            <div class="col-md-2 col-form-label text-md-end text-start">
                <strong>@Html.DisplayNameFor(m => m.UpdatedAt)：</strong>
            </div>
            <div class="col-md-4 pt-1">
                @{
                    var updatedText = Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "(無)";
                }
                @updatedText
            </div>
        </div>

        <hr />

        <!-- 成員清冊 -->
        <div class="my-3">
            <h5 class="mb-2">
                <i class="bi bi-people-fill me-1"></i>使用者群組成員清冊
                @if (Model.UserGroupMembers.Any())
                {
                    <span class="badge bg-secondary ms-2">@Model.UserGroupMembers.Count 人</span>
                }
            </h5>

            @if (!Model.UserGroupMembers.Any())
            {
                <div class="text-muted">(無成員)</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>
                                    @Html.DisplayNameFor(m => m.UserGroupMembers.FirstOrDefault().UserId)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m.UserGroupMembers.FirstOrDefault().User.UserAccount)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m.UserGroupMembers.FirstOrDefault().User.UserFullName)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m.UserGroupMembers.FirstOrDefault().User.Department.DepartmentName)
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model.UserGroupMembers)
                            {
                                <tr>
                                    <td>@member.UserId</td>
                                    <td>@member.User?.UserAccount</td>
                                    <td>@member.User?.UserFullName</td>
                                    <td>
                                        @(string.IsNullOrEmpty(member.User?.Department?.DepartmentName)
                                                                        ? "(無)"
                                                                        : member.User!.Department!.DepartmentName)
                            </td>
                        </tr>
                                                }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <hr />

        <!-- 角色清冊 -->
        <div class="my-3">
            <h5 class="mb-2">
                <i class="bi bi-shield-lock-fill me-1"></i>使用者群組角色清冊
                @if (Model.UserGroupRoles.Any())
                {
                    <span class="badge bg-secondary ms-2">
                        有 @Model.UserGroupRoles.Count 個角色使用該群組
                    </span>
                }
            </h5>

            @if (!Model.UserGroupRoles.Any())
            {
                <div class="text-muted">(無角色)</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>
                                    @Html.DisplayNameFor(m => m.UserGroupRoles.FirstOrDefault().RoleId)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m.UserGroupRoles.FirstOrDefault().Role.RoleGroup)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m.UserGroupRoles.FirstOrDefault().Role.RoleCode)
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.UserGroupRoles)
                            {
                                <tr>
                                    <td>@r.RoleId</td>
                                    <td>@r.Role?.RoleGroup</td>
                                    <td>@r.Role?.RoleCode</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>

@section PageScripts {
    <script nonce="@ViewBag.CspNonce">

    </script>
}
