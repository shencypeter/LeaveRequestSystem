{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    // 【SQL Server-Windows登入】 (DBserver和APserver同一台才可以這樣用)
    //"DefaultConnection": "Server=localhost;Database=DocControl;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;",

    // 【SQLEXPRESS-Windows登入】 (DBserver和APserver同一台才可以這樣用)
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=DocControl0;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;"

    // 【SQLEXPRESS-SQL驗證登入】
    //"DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=DocControl;TrustServerCertificate=True;User Id=doc_user;Password=PASSWORD;"

  },
  "AllowedHosts": "*",
  "ExceptionLogPath": "Logs\\Exceptions", // 絕對路徑
  //"ExceptionLogPath": "C:\\Logs\\Exceptions", // 絕對路徑範例
  "LoginFailedLimit": 3,
  "LoginLockTime": 15

